# Sanity content API (primary)
SANITY_PROJECT_ID=
SANITY_DATASET=
# Generate a read token in Sanity (Project Settings > API) and paste it here
SANITY_API_TOKEN=
# Optional CDN controls
SANITY_USE_CDN=true
SANITY_FORCE_REFRESH=false
# Cache duration for Sanity queries (e.g. 1d, 6h, 30m)
SANITY_CACHE_DURATION=1d

# Figma API Configuration
FIGMA_FILE_ID=
FIGMA_TOKEN=

# Legacy (supported but deprecated):
# FIGMA_ACCESS_TOKEN=

# Asset Configuration
IMAGE_PATH=/content/images/

# Development Options
DEBUG=true