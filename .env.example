# Sanity content API (primary)
SANITY_PROJECT_ID=
SANITY_DATASET=
SANITY_PARALLEL=true
# Generate a read token in Sanity (Project Settings > API) and paste it here
SANITY_READ_TOKEN=
# Optional CDN controls
SANITY_USE_CDN=true
SANITY_FORCE_REFRESH=false
# Cache duration for Sanity queries (e.g. 1d, 6h, 30m)
SANITY_CACHE_DURATION=1d
# Sanity API version used by the contact form's direct mutation write
SANITY_API_VERSION=2026-03-01
# Sanity WRITE token for the contact form (Project Settings > API > Tokens, role: Editor).
# WARNING: injected at build time and PRESENT IN THE DEPLOYED HTML as a data
# attribute. Accepted tradeoff for this portfolio — use a minimal-permission
# (write, not delete/manage) token. See contact form spec §4.
SANITY_WRITE_TOKEN=

# Figma API Configuration
FIGMA_FILE_ID=
FIGMA_TOKEN=

# Legacy (supported but deprecated):
# FIGMA_ACCESS_TOKEN=

# Asset Configuration
IMAGE_PATH=/content/images/

# Development Options
DEBUG=true