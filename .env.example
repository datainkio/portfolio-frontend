# Sanity content API (primary)
SANITY_PROJECT_ID=
SANITY_DATASET=
# Generate a read token in Sanity (Project Settings > API) and paste it here
SANITY_API_TOKEN=
# Optional CDN controls
SANITY_USE_CDN=true
SANITY_FORCE_REFRESH=false

# Airtable CMS (legacy; scheduled for deprecation)
AIRTABLE_PERSONAL_ACCESS_TOKEN=
AIRTABLE_BASE_TOKEN=
# Optional debug/refresh controls
AIRTABLE_PARALLEL=false
# FORCE_REFRESH=true
# FORCE_REFRESH_TABLE=

# Figma API Configuration
FIGMA_FILE_ID=
FIGMA_TOKEN=

# Legacy (supported but deprecated):
# FIGMA_ACCESS_TOKEN=

# Asset Configuration
IMAGE_PATH=/content/images/

# Development Options
DEBUG=true