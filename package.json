{
  "name": "datainkio",
  "author": "Russell Lebo",
  "description": "Personal work portfolio, beotch",
  "type": "module",
  "version": "2.0.0",
  "main": "index.js",
  "keywords": [],
  "license": "ISC",
  "scripts": {
    "clean": "node scripts/clearSiteFolder.js",
    "clean:debug": "DEBUG=true node scripts/clearSiteFolder.js",
    "sync:content": "node scripts/syncContent.js",
    "sync:content:debug": "DEBUG=true node scripts/syncContent.js",
    "sync:content:force": "FORCE_REFRESH=true node scripts/syncContent.js",
    "build": "run-s clean sync:content build:*",
    "build:debug": "DEBUG=true run-s clean:debug sync:content:debug build:*",
    "build:force": "FORCE_REFRESH=true run-s clean sync:content:force build:*",
    "build:css": "npx @tailwindcss/cli -i styles/main.css -o _site/assets/styles.css",
    "build:design": "node scripts/fetchFigma.js",
    "build:design:debug": "DEBUG=true node scripts/fetchFigma.js",
    "build:11ty": "eleventy --quiet",
    "dev:11ty": "eleventy --serve --quiet",
    "dev:css": "npx @tailwindcss/cli -i styles/main.css -o _site/assets/styles.css --watch",
    "dev": "run-p dev:css dev:11ty",
    "start": "run-s dev",
    "test": "node test/logger/index.js",
    "test:logger": "node test/logger/index.js",
    "test:logger:styles": "DEBUG=true node test/logger/styles.test.js",
    "test:logger:errors": "DEBUG=true node test/logger/errors.test.js",
    "test:logger:optional": "DEBUG=true node test/logger/optional-parameter.test.js",
    "test:logger:detection": "DEBUG=true node test/logger/error-detection.test.js",
    "test:logger:realworld": "DEBUG=true node test/logger/real-world.test.js",
    "test:logger:custom": "DEBUG=true node test/logger/custom-styles.test.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:njk": "prettier --write \"**/*.njk\""
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-fetch": "^5.0.1",
    "@11ty/eleventy-img": "^5.0.0",
    "@11ty/eleventy-navigation": "^0.3.5",
    "@svgdotjs/svg.js": "^3.2.4",
    "@tailwindcss/upgrade": "^4.0.2",
    "airtable": "^0.12.2",
    "ansi-colors": "^4.1.3",
    "chalk": "^5.4.1",
    "cheerio": "^1.0.0",
    "cli-progress": "^3.12.0",
    "dotenv": "^16.4.7",
    "html-minifier": "^4.0.0",
    "lorem-ipsum": "^2.0.8",
    "markdown-it": "^14.1.0",
    "npm-run-all": "^4.1.5",
    "opentype.js": "^1.3.4",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "prettier": "^3.6.2"
  }
}
