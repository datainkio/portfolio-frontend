---
layout: templates/documentation.njk
title: Content Strategy
eleventyNavigation:
  key: Content Strategy
  parent: About
---
  {# Sanity projects summary #}
  {% set sanityProjects = collections.sanityProjects | default([]) %}
  {% set publishedCount = 0 %}
  {% set unpublishedCount = 0 %}
  {% for project in sanityProjects %}
    {% if project.data.published %}
      {% set publishedCount = publishedCount + 1 %}
    {% else %}
      {% set unpublishedCount = unpublishedCount + 1 %}
    {% endif %}
  {% endfor %}
  <section class="mx-auto max-w-5xl px-6 py-8 text-neutral-100">
    <h2 class="text-lg font-semibold">Sanity Projects Summary</h2>
    <dl class="mt-3 grid grid-cols-3 gap-4 text-sm">
      <div class="rounded-lg bg-neutral-800 px-4 py-3">
        <dt class="text-neutral-400">Total</dt>
        <dd class="text-xl font-bold">{{ sanityProjects | length }}</dd>
      </div>
      <div class="rounded-lg bg-neutral-800 px-4 py-3">
        <dt class="text-neutral-400">Published</dt>
        <dd class="text-xl font-bold">{{ publishedCount }}</dd>
      </div>
      <div class="rounded-lg bg-neutral-800 px-4 py-3">
        <dt class="text-neutral-400">Unpublished</dt>
        <dd class="text-xl font-bold">{{ unpublishedCount }}</dd>
      </div>
    </dl>
  </section>