---
layout: templates/documentation.njk
title: Colors
eleventyNavigation:
  key: Colors
  parent: Design
---

<div
  class="grid col-span-full grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-4 p-4"
>
  {% for colorName, shades in styles.colors %}
    <div>
      <h3 class="text-lg font-bold">{{ colorName }}</h3>
      <div class="space-y-2 mt-2">
        {% for shade, hex in shades %}
          <div class="flex items-center">
            <div
              class="w-8 h-8 rounded-sm"
              style="background-color: {{ hex }}"
            ></div>
            <span class="ml-2">{{ shade }}: {{ hex }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endfor %}
</div>
{#
  Iterate through the colors and generate the outcome of applying a multiply blend to each color pair.
  Use a set (displayedPairs) to keep track of the color pairs that have already been displayed. The 
  pairs are sorted and joined into a string to ensure that primary/secondary and secondary/primary are 
  considered the same pair. This way, each pair is displayed only once.

  Assumes that styles.colors is defined and supplying values from the current theme.
#}

<div
  class="grid col-span-full grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 p-4"
>
  <div class="col-span-full flex items-center gap-4">
    <h2 class="text-xl font-bold">Color Blend Combinations</h2>
    <select class="select select-bordered w-48 blend-mode-selector">
      <option value="multiply">Multiply</option>
      <option value="screen">Screen</option>
      <option value="overlay">Overlay</option>
      <option value="darken">Darken</option>
      <option value="lighten">Lighten</option>
      <option value="color-dodge">Color Dodge</option>
      <option value="color-burn">Color Burn</option>
      <option value="hard-light">Hard Light</option>
      <option value="soft-light">Soft Light</option>
      <option value="difference">Difference</option>
      <option value="exclusion">Exclusion</option>
    </select>
  </div>

  {% set displayedPairs = [] %}
  {% for colorName1, shades1 in styles.colors %}
    {% for colorName2, shades2 in styles.colors %}
      {% set pairKey = [colorName1, colorName2] | sort | join('-') %}
      {% if colorName1 != colorName2 and pairKey not in displayedPairs %}
        {% set displayedPairs = displayedPairs.concat(pairKey) %}
        <div class="card bg-base-100 shadow-xl hover:text-gray-200">
          <div class="card-body p-4">
            <h3 class="card-title">{{ colorName1 }} × {{ colorName2 }}</h3>
            <div class="space-y-2">
              {% for shade1, hex1 in shades1 %}
                {% for shade2, hex2 in shades2 %}
                  {% set blendedHex = hex1 | multiplyBlend(hex2) %}
                  <div
                    class="flex items-center gap-2"
                    data-color1="{{ hex1 }}"
                    data-color2="{{ hex2 }}"
                    data-shade1="{{ shade1 }}"
                    data-shade2="{{ shade2 }}"
                  >
                    <div
                      class="w-8 h-8 rounded-btn"
                      style="background-color: {{ hex1 }}"
                    ></div>
                    <div
                      class="w-8 h-8 rounded-btn"
                      style="background-color: {{ hex2 }}"
                    ></div>
                    <div class="w-16 h-8 rounded-btn relative blend-preview">
                      <div
                        class="absolute inset-0"
                        style="background-color: {{ hex1 }}"
                      ></div>
                      <div
                        class="absolute inset-0 blend-layer"
                        style="background-color: {{ hex2 }}"
                      ></div>
                    </div>
                    <span class="ml-2 text-sm blend-result"
                      >{{ shade1 }} × {{ shade2 }}: {{ blendedHex }}</span
                    >
                  </div>
                {% endfor %}
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  {% endfor %}
</div>

<script>
  const blendModeSelector = document.querySelector('.blend-mode-selector');
  const blendPreviews = document.querySelectorAll('.blend-preview');

  function updateBlendMode(mode) {
    document.querySelectorAll('.blend-layer').forEach(el => {
      el.style.mixBlendMode = mode;
    });

    // Update blend results
    document.querySelectorAll('[data-color1]').forEach(container => {
      const color1 = container.dataset.color1;
      const color2 = container.dataset.color2;
      const shade1 = container.dataset.shade1;
      const shade2 = container.dataset.shade2;
      const blendedHex = calculateBlend(color1, color2, mode);
      container.querySelector('.blend-result').textContent =
        `${shade1} × ${shade2}: ${blendedHex}`;
    });
  }

  blendModeSelector.addEventListener('change', e =>
    updateBlendMode(e.target.value)
  );

  // Initialize with multiply blend mode
  updateBlendMode('multiply');
</script>

<style>
  .blend-layer {
    mix-blend-mode: multiply;
  }
</style>
