---
layout: templates/base.njk
permalink: /dev/components/
title: 'Component Library'
subtitle: 'Design System Testing & Documentation'
metaDescription: 'Component testing page for dataink.io design system'
metaKeywords: 'components, design system, testing, development'
canonicalUrl: 'https://dataink.io/dev/components/'
bodyStyles: 'bg-neutral-light'
headerClasses: 'text-neutral-dark'
eleventyExcludeFromCollections: true
---

{% import "molecules/callout.njk" as callout %}

{# Component Library Testing Page #}
{# 
CRITICAL WARNING: This page is for DEVELOPMENT ONLY
- Tests core components with sample data
- Validates design token integration
- DO NOT include in production builds

TESTING SCOPE:
- Icon component (consolidated system)
- Button component (enhanced with frontmatter)
- Component documentation and usage examples
#}

<style>
  .component-showcase {
    @apply mb-8 p-6 border border-neutral-300 rounded-lg max-w-4xl mx-auto;
  }
  .component-example {
    @apply mb-6 p-4 bg-neutral-50 rounded border;
  }
  .component-code {
    @apply mt-2 p-2 bg-neutral-800 text-neutral-100 text-xs rounded font-mono;
  }
</style>

<main class="component-library px-4 py-8">
  
  <header class="mb-8 text-center">
    <h1 class="text-4xl font-bold mb-4">{{ title }}</h1>
    <p class="text-xl text-neutral-600 mb-4">{{ subtitle }}</p>
    
    <div class="bg-yellow-100 border border-yellow-400 text-yellow-800 px-4 py-3 rounded mb-4">
      <strong>⚠️ Development Environment:</strong> Component testing with live design tokens.
    </div>
  </header>

  <!-- ICON SYSTEM TESTING -->
  <section class="component-showcase">
    <h2 class="text-2xl font-bold mb-4">🔬 Icon Component (Consolidated System)</h2>
    
    <div class="component-example">
      <h3 class="font-semibold mb-2">Direction Icons</h3>
      {% set name = "direction-left" %}
      {% set size = "md" %}
      {% set className = "text-blue-500 mr-2" %}
      {% include "atoms/icon.njk" %}
      
      {% set name = "direction-right" %}
      {% include "atoms/icon.njk" %}
      
      <div class="component-code">
        {% set name = "direction-left" %}<br>
        {% set size = "md" %}<br>
        {% set className = "text-blue-500" %}<br>
        {% include "atoms/icon.njk" %}
      </div>
    </div>
    
    <div class="component-example">
      <h3 class="font-semibold mb-2">Size Variations</h3>
      {% set name = "chevron-down" %}
      {% set className = "text-neutral-600 mr-1" %}
      
      {% set size = "xs" %}{% include "atoms/icon.njk" %}
      {% set size = "sm" %}{% include "atoms/icon.njk" %}
      {% set size = "md" %}{% include "atoms/icon.njk" %}
      {% set size = "lg" %}{% include "atoms/icon.njk" %}
      {% set size = "xl" %}{% include "atoms/icon.njk" %}
      {% set size = "2xl" %}{% include "atoms/icon.njk" %}
      
      <div class="component-code">
        Sizes: xs, sm, md, lg, xl, 2xl
      </div>
    </div>
    
    <div class="component-example">
      <h3 class="font-semibold mb-2">Error Handling</h3>
      {% set name = "nonexistent-icon" %}
      {% set size = "md" %}
      {% set className = "mr-2" %}
      {% include "atoms/icon.njk" %}
      <span class="text-sm text-neutral-600">← Shows error indicator for missing icons</span>
      
      <div class="component-code">
        {% set name = "nonexistent-icon" %} {# Missing icon shows red error box #}
      </div>
    </div>
  </section>

  <!-- SCAFFOLDING INFO -->
  <section class="component-showcase">
    <h2 class="text-2xl font-bold mb-4">🛠️ Component Development</h2>
    
    <div class="bg-green-50 border border-green-200 p-4 rounded mb-4">
      <h3 class="font-bold mb-2 text-green-800">Scaffolding Commands</h3>
      <div class="font-mono text-sm space-y-1">
        <div>npm run scaffold:component atoms progress-bar</div>
        <div>npm run scaffold:component molecules project-card</div>
        <div>npm run scaffold:page portfolio</div>
        <div>npm run scaffold:list</div>
      </div>
    </div>
    
    <div class="bg-blue-50 border border-blue-200 p-4 rounded">
      <h3 class="font-bold mb-2 text-blue-800">✅ Enhanced Features</h3>
      <ul class="text-sm space-y-1">
        <li>• Consolidated icon system (9 built-in icons)</li>
        <li>• Component scaffolding with standardized frontmatter</li>
        <li>• GSAP animation integration warnings</li>
        <li>• Figma design token compatibility</li>
        <li>• Airtable content binding support</li>
      </ul>
    </div>
  </section>

  <!-- MOLECULE TESTING -->
  <section class="component-showcase">
    <h2 class="text-2xl font-bold mb-4">🧩 Molecule Component (Macro): Callout</h2>

    <div class="component-example">
      <h3 class="font-semibold mb-2">Basic Usage</h3>
      {{ callout.render({
        title: "Reusable macro molecule",
        tone: "info",
        text: "This callout is rendered via a Nunjucks macro imported from molecules/callout.njk."
      }) }}
    </div>

    <div class="component-example">
      <h3 class="font-semibold mb-2">Rich Content (call/endcall)</h3>
      {% call callout.render({ title: "Tip", tone: "success" }) %}
        <p class="m-0">Use <code class="px-1 rounded bg-white/60">{% raw %}{% call %}{% endraw %}</code> when you want links, lists, or multiple paragraphs.</p>
      {% endcall %}
    </div>
  </section>

  <!-- FILTER TESTING -->
  <section class="component-showcase">
    <h2 class="text-2xl font-bold mb-4">🧪 Eleventy Filters: formatDate</h2>

    <div class="component-example">
      <h3 class="font-semibold mb-2">Default (DATE_MED)</h3>
      <p class="text-sm text-neutral-700 m-0">{{ page.date | formatDate }}</p>
      <div class="component-code">
        {{ '{' }}{ page.date | formatDate }{{ '}' }}
      </div>
    </div>

    <div class="component-example">
      <h3 class="font-semibold mb-2">Custom format string</h3>
      <p class="text-sm text-neutral-700 m-0">{{ page.date | formatDate('DDD') }}</p>
      <div class="component-code">
        {{ '{' }}{ page.date | formatDate('DDD') }{{ '}' }}
      </div>
    </div>
  </section>

</main>