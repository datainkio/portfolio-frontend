---
layout: templates/documentation.njk
title: Text Party
description: Demonstrate text effects
eleventyNavigation:
  key: Text Party
  parent: Lab
scripts: >
  <script src="https://cdnjs.cloudflare.com/ajax/libs/opentype.js/1.3.4/opentype.min.js"></script>
---

<section>
  <h2>Text Morphing</h2>
  <p id="textMorph">INK</p>
  <script type="module">
    // Import GSAP dependencies first
    import { gsap } from '/assets/js/gsap/all.js';
    import { SplitText } from '/assets/js/gsap/SplitText.js';
    import { CustomEase } from '/assets/js/gsap/CustomEase.js';
    import { CustomWiggle } from '/assets/js/gsap/CustomWiggle.js';
    import { MorphSVGPlugin } from '/assets/js/gsap/MorphSVGPlugin.js';

    // Register GSAP plugins
    gsap.registerPlugin(SplitText, CustomEase, CustomWiggle, MorphSVGPlugin);

    // Make GSAP available globally for TextParty
    window.gsap = gsap;
    window.SplitText = SplitText;
    window.CustomEase = CustomEase;
    window.CustomWiggle = CustomWiggle;
    window.MorphSVGPlugin = MorphSVGPlugin;

    import * as TextParty from '/assets/js/effects/TextParty.js';
    // Define the fonts for the morphing text
    const fonts = [
      {
        name: 'Big Shoulders Display',
        url: '/assets/fonts/Big_Shoulders_Display/static/BigShouldersDisplay-Regular.ttf',
        kerning: 0.85,
        size: 125,
      },
      {
        name: 'Twinkle Star',
        url: '/assets/fonts/Twinkle_Star/TwinkleStar-Regular.ttf',
        kerning: 1,
        size: 110,
      },
      {
        name: 'Playwrite',
        url: '/assets/fonts/Playwrite_AU_SA/static/PlaywriteAUSA-Regular.ttf',
        kerning: 0.9,
        size: 80,
      },
      // Add more fonts as desired
    ];
    TextParty.morph('textMorph', fonts);
  </script>
</section>
<section>
  <h2>Text Network</h2>
  <canvas id="myCanvas"></canvas>
  <script src="/assets/js/effects/text/text-network.js"></script>
</section>
<section>
  <h2>Text Masking</h2>
  {% set textFormat = "text-12xl uppercase font-black tracking-tight leading-none" %} {% set clipping = "bg-clip-text
  text-transparent mix-blend-multiply" %} {% set background = "bg-[url(/video/zabiela_bg.mp4)]" %}
  <div>
    <h3>Display a different color behind each character</h3>
    <span id="rainbow" class="{{ textFormat }}">data:ink:io</span>
  </div>
  <div>
    <h3>Display a different image behind each character</h3>
    <span id="image" class="{{ textFormat }}">data:ink:io</span>
  </div>
  <div>
    <h3>Display a video as the background for the complete string</h3>
    {% set svgStyles = "w-full h-48 overflow-visible" %}
    <svg class="{{ svgStyles }}" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <clipPath id="text-clip">
          <text class="{{ textFormat }}" x="0" y="0" alignment-baseline="hanging">data:ink:io</text>
        </clipPath>
      </defs>
      <!-- Video with Clip Path -->
      <foreignObject width="100%" height="100%" clip-path="url(#text-clip)">
        <video width="100%" height="100%" autoplay loop muted>
          <source src="/video/zabiela_bg.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </foreignObject>
    </svg>
  </div>
  <div>
    <h2>Display a different video behind each character</h2>
    <span id="video" class="{{ textFormat }}">data:ink:io</span>
  </div>
  <script>
    // Split text into individual divs
    gsap.registerPlugin(SplitText);
    document.fonts.ready.then(() => {
      rainbow();
      image();
      video();
    });
    function animate(chars) {
      gsap.to(chars, {
        duration: 1,
        backgroundClip: 'text',
        color: 'transparent',
        stagger: 0.01,
        ease: 'power2.inOut',
      });
    }
    function rainbow() {
      const split = new SplitText('#rainbow', {
        type: 'chars',
        charsClass: 'char',
      });
      split.chars.forEach((char, i) => {
        char.style.background = `hsl(${(i * 10 + gsap.utils.wrap(0, 360, i * 10)) % 360}, 100%, 50%)`;
      });
      animate(split.chars);
    }
    function image() {
      const split = new SplitText('#image', {
        type: 'chars',
        charsClass: 'char',
      });
      split.chars.forEach((char, i) => {
        char.style.background = `url(https://picsum.photos/200/300?random=${i})`;
      });
      animate(split.chars);
    }
    // Just a bunch of videos for demo purposes
    const videos = [
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ElephantsDream.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerEscapes.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerFun.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerJoyrides.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerMeltdowns.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/Sintel.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/SubaruOutbackOnStreetAndDirt.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/TearsOfSteel.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/VolkswagenGTIReview.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/WeAreGoingOnBullrun.mp4',
      'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/WhatCarCanYouGetForAGrand.mp4',
    ];
    function video() {
      // Split the text into divs with unique class names
      const split = new SplitText('#video', {
        type: 'chars',
        charsClass: 'char_++',
      });
      // Create/append the SVG to the parent of #video
      const parent = document.getElementById('video').parentElement;
      let svg;
      if (parent) {
        svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        // svg.setAttribute("viewBox", "0 0 1200 150");
        svg.classList.add('w-full', 'h-48', 'overflow-visible');
        // Create a <defs> tag to hold all clipPaths
        const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
        svg.appendChild(defs);
        parent.appendChild(svg);
      }
      // Track horizontal offset so characters align in one line
      let xOffset = 0;
      // For each character, add a text clip path and a matching rectangle
      split.chars.forEach((char, i) => {
        if (!svg) return;

        const defs = svg.querySelector('defs');
        // Create clipPath
        const clipPath = document.createElementNS('http://www.w3.org/2000/svg', 'clipPath');
        clipPath.setAttribute('id', `clipChar${i}`);
        // Create text element that matches the display of the original text
        const textElem = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        textElem.classList.add('text-12xl', 'uppercase', 'font-black', 'tracking-tight', 'leading-none');
        textElem.setAttribute('x', xOffset.toString());
        textElem.setAttribute('y', '0'); // baseline for all characters
        textElem.setAttribute('text-anchor', 'start');
        textElem.setAttribute('alignment-baseline', 'hanging');
        textElem.textContent = char.textContent;
        clipPath.appendChild(textElem);
        defs.appendChild(clipPath);
        // Measure the width and height of the character
        const charRect = char.getBoundingClientRect();
        const charWidth = charRect.width;
        const charHeight = charRect.height;
        // Randomly select a video from the videos array
        const videoUrl = videos[Math.floor(Math.random() * videos.length)];
        // Create a foreignObject with a video element, referencing the appropriate clip path
        const foreignObject = document.createElementNS('http://www.w3.org/2000/svg', 'foreignObject');
        foreignObject.setAttribute('x', xOffset.toString());
        foreignObject.setAttribute('y', '0');
        foreignObject.setAttribute('width', 500);
        foreignObject.setAttribute('height', 500);
        foreignObject.setAttribute('clip-path', `url(#clipChar${i})`);
        // Create the video element
        const videoElem = document.createElement('video');
        videoElem.setAttribute('width', '500');
        videoElem.setAttribute('height', '500');
        videoElem.setAttribute('autoplay', 'true');
        videoElem.setAttribute('loop', 'true');
        videoElem.setAttribute('muted', 'true');
        // Set the source for the video
        const sourceElem = document.createElement('source');
        sourceElem.setAttribute('src', videoUrl);
        sourceElem.setAttribute('type', 'video/mp4');
        videoElem.appendChild(sourceElem);
        foreignObject.appendChild(videoElem);
        svg.appendChild(foreignObject);
        // Update the horizontal offset for the next character
        xOffset += charWidth;
      });
    }
  </script>
</section>
