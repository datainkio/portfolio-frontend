---
layout: templates/documentation.njk
title: Text Party
description: Demonstrate text effects
eleventyNavigation:
  key: Text Party
  parent: Lab
scripts: >
  <script src="https://cdnjs.cloudflare.com/ajax/libs/opentype.js/1.3.4/opentype.min.js"></script>
---

<!-- CRITICAL: GSAP Setup - Import once at page level for all sections -->
<script type="module">
  // Import and configure GSAP
  import {gsap} from '/assets/js/gsap/all.js';
  import {SplitText} from '/assets/js/gsap/SplitText.js';
  import {CustomEase} from '/assets/js/gsap/CustomEase.js';
  import {CustomWiggle} from '/assets/js/gsap/CustomWiggle.js';
  import {MorphSVGPlugin} from '/assets/js/gsap/MorphSVGPlugin.js';
  import * as TextParty from '/assets/js/effects/TextParty.js';

  gsap.registerPlugin(SplitText, CustomEase, CustomWiggle, MorphSVGPlugin);
  Object.assign(window, {gsap, SplitText, CustomEase, CustomWiggle, MorphSVGPlugin, TextParty});

  // State management
  const state = {
    titleRoll: null,
    textMorph: null,
    rainbowSplit: null,
    imageSplit: null,
    videoSplit: null
  };

  const FONTS = [
    {name: 'Big Shoulders Display', url: '/assets/fonts/Big_Shoulders_Display/static/BigShouldersDisplay-Regular.ttf', kerning: 0.85, size: 125},
    {name: 'Twinkle Star', url: '/assets/fonts/Twinkle_Star/TwinkleStar-Regular.ttf', kerning: 1, size: 110},
    {name: 'Playwrite', url: '/assets/fonts/Playwrite_AU_SA/static/PlaywriteAUSA-Regular.ttf', kerning: 0.9, size: 80}
  ];

  const VIDEOS = [
    'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4',
    'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ElephantsDream.mp4',
    'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerBlazes.mp4',
    'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerEscapes.mp4',
    'http://commondatastorage.googleapis.com/gtv-videos-bucket/sample/Sintel.mp4'
  ];

  // Utility functions
  const $ = id => document.getElementById(id);
  const killTimeline = tl => tl?.kill();
  const revertSplit = split => split?.revert();

  // Event delegation for buttons
  const setupHandlers = () => {
    const handlers = {
      'btn-title-start': () => state.titleRoll = TextParty.roll($('titlesequence'), {id: 'titlesequence-roll', rotation: 90, y_delta: 100, duration: 1.5, ease: 'power2.out'}),
      'btn-title-stop': () => state.titleRoll?.pause(),
      'btn-morph-start': () => state.textMorph = TextParty.morph('textMorph', FONTS),
      'btn-morph-stop': () => {
        gsap.globalTimeline.getChildren(true, true, true).forEach(t => {
          if (t.targets?.()?.some(el => el === '#textSVG' || el?.id === 'textSVG' || el?.matches?.('#textSVG path'))) t.kill();
        });
        const el = $('textMorph');
        if (el) {el.innerHTML = 'INK'; el.style.color = '';}
        state.textMorph = null;
      },
      'btn-rainbow-apply': () => applyMask('rainbow', (char, i) => char.style.background = `hsl(${(i * 36) % 360}, 100%, 50%)`),
      'btn-rainbow-reset': () => resetMask('rainbowSplit'),
      'btn-image-apply': () => applyMask('image', (char, i) => {
        char.style.background = `url(https://picsum.photos/200/300?random=${i})`;
        char.style.backgroundSize = 'cover';
        char.style.backgroundPosition = 'center';
      }),
      'btn-image-reset': () => resetMask('imageSplit'),
      'btn-video-apply': () => applyVideoMask(),
      'btn-video-reset': () => {
        const parent = $('video')?.parentElement;
        parent?.querySelector('svg')?.remove();
        revertSplit(state.videoSplit);
        state.videoSplit = null;
      }
    };

    Object.entries(handlers).forEach(([id, handler]) => {
      const btn = $(id);
      if (btn) btn.addEventListener('click', handler);
    });
  };

  // Text mask utilities
  const applyMask = (id, styleFn) => {
    const el = $(id);
    if (!el) return;
    
    const split = new SplitText(el, {type: 'chars', charsClass: 'char'});
    state[`${id}Split`] = split;
    
    split.chars.forEach(styleFn);
    gsap.to(split.chars, {duration: 1, backgroundClip: 'text', color: 'transparent', stagger: 0.01, ease: 'power2.inOut'});
  };

  const resetMask = key => {
    revertSplit(state[key]);
    state[key] = null;
  };

  // Video mask implementation
  const applyVideoMask = () => {
    const el = $('video');
    const parent = el?.parentElement;
    if (!el || !parent) return;

    parent.querySelector('svg')?.remove();

    const split = new SplitText(el, {type: 'chars', charsClass: 'char_++'});
    state.videoSplit = split;

    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.classList.add('w-full', 'h-48', 'overflow-visible');
    const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
    svg.appendChild(defs);
    parent.appendChild(svg);

    let xOffset = 0;
    split.chars.forEach((char, i) => {
      const clipPath = document.createElementNS('http://www.w3.org/2000/svg', 'clipPath');
      clipPath.id = `clipChar${i}`;

      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.classList.add('text-12xl', 'uppercase', 'font-black', 'tracking-tight', 'leading-none');
      Object.assign(text, {textContent: char.textContent});
      ['x', 'y', 'text-anchor', 'alignment-baseline'].forEach((attr, idx) => 
        text.setAttribute(attr, [xOffset, '0', 'start', 'hanging'][idx])
      );

      clipPath.appendChild(text);
      defs.appendChild(clipPath);

      const fo = document.createElementNS('http://www.w3.org/2000/svg', 'foreignObject');
      ['x', 'y', 'width', 'height', 'clip-path'].forEach((attr, idx) => 
        fo.setAttribute(attr, [xOffset, '0', '500', '500', `url(#clipChar${i})`][idx])
      );

      const video = Object.assign(document.createElement('video'), {
        width: 500, height: 500, autoplay: true, loop: true, muted: true, playsInline: true
      });
      const source = Object.assign(document.createElement('source'), {
        src: VIDEOS[Math.floor(Math.random() * VIDEOS.length)],
        type: 'video/mp4'
      });

      video.appendChild(source);
      fo.appendChild(video);
      svg.appendChild(fo);

      xOffset += char.getBoundingClientRect().width;
    });
  };

  // Initialize
  (document.readyState === 'loading' 
    ? document.addEventListener('DOMContentLoaded', setupHandlers) 
    : setupHandlers());
</script>

<section>
  <h2>Title Sequence</h2>
  <div class="mb-4 flex gap-2">
    <button id="btn-title-start" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
      Start Animation
    </button>
    <button id="btn-title-stop" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition">
      Stop Animation
    </button>
  </div>
  <p id="titlesequence" class="text-4xl font-bold">DATA:INK:IO</p>
</section>

<section>
  <h2>Text Morphing</h2>
  <div class="mb-4 flex gap-2">
    <button id="btn-morph-start" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
      Start Animation
    </button>
    <button id="btn-morph-stop" class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition">
      Stop Animation
    </button>
  </div>
  <p id="textMorph" class="text-6xl font-bold">INK</p>
</section>

<section>
  <h2>Text Network</h2>
  <canvas id="myCanvas" width="800" height="600" class="w-full border border-slate-300"></canvas>
  <script src="/assets/js/effects/text/TextNetwork.js"></script>
</section>

<section>
  <h2>Text Masking</h2>
  {% set textFormat = "text-12xl uppercase font-black tracking-tight leading-none" %}

  <div class="mb-12">
    <h3 class="text-xl font-semibold mb-4">Rainbow Effect</h3>
    <p class="text-sm text-slate-600 mb-4">Display a different color behind each character</p>
    <div class="mb-4 flex gap-2">
      <button id="btn-rainbow-apply" class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition">
        Apply Effect
      </button>
      <button id="btn-rainbow-reset" class="px-4 py-2 bg-slate-600 text-white rounded hover:bg-slate-700 transition">
        Reset
      </button>
    </div>
    <span id="rainbow" class="{{ textFormat }}" aria-label="data ink io">data:ink:io</span>
  </div>

  <div class="mb-12">
    <h3 class="text-xl font-semibold mb-4">Image Mask Effect</h3>
    <p class="text-sm text-slate-600 mb-4">Display a different image behind each character</p>
    <div class="mb-4 flex gap-2">
      <button id="btn-image-apply" class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition">
        Apply Effect
      </button>
      <button id="btn-image-reset" class="px-4 py-2 bg-slate-600 text-white rounded hover:bg-slate-700 transition">
        Reset
      </button>
    </div>
    <span id="image" class="{{ textFormat }}" aria-label="data ink io">data:ink:io</span>
  </div>

  <div class="mb-12">
    <h3 class="text-xl font-semibold mb-4">Video Background (Full String)</h3>
    <p class="text-sm text-slate-600 mb-4">Display a video as the background for the complete string</p>
    <svg class="w-full h-48 overflow-visible" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <clipPath id="text-clip">
          <text class="{{ textFormat }}" x="0" y="0" alignment-baseline="hanging">data:ink:io</text>
        </clipPath>
      </defs>
      <foreignObject width="100%" height="100%" clip-path="url(#text-clip)">
        <video width="100%" height="100%" autoplay loop muted playsinline>
          <source src="/video/zabiela_bg.mp4" type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </foreignObject>
    </svg>
  </div>

  <div class="mb-12">
    <h3 class="text-xl font-semibold mb-4">Video Mask (Per Character)</h3>
    <p class="text-sm text-slate-600 mb-4">Display a different video behind each character</p>
    <div class="mb-4 flex gap-2">
      <button id="btn-video-apply" class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition">
        Apply Effect
      </button>
      <button id="btn-video-reset" class="px-4 py-2 bg-slate-600 text-white rounded hover:bg-slate-700 transition">
        Reset
      </button>
    </div>
    <span id="video" class="{{ textFormat }}" aria-label="data ink io">data:ink:io</span>
  </div>
</section>