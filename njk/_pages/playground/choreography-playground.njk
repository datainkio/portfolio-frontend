---
layout: null
permalink: /playground/choreography/
title: 'Choreography Playground'
metaDescription: 'Event-driven harness to emit, observe, and iterate on choreography events.'
scripts: >
  <script type="module" src="/assets/js/choreography-playground.js"></script>
---
<!DOCTYPE html>
<html lang="en">
  {% include "templates/partials/head.njk" %}
  <body class="bg-neutral-950 text-neutral-50">
    <main class="min-h-screen">
      <header class="sticky top-0 z-30 border-b border-neutral-800 bg-neutral-950/90 backdrop-blur">
        <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-[11px] uppercase tracking-[0.18em] text-primary-300">Choreography Playground</p>
              <p class="text-sm text-neutral-300">Emit and observe AnimationBus events without rebuilding.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2 text-xs text-neutral-300">
              <span id="status-active-mode" class="rounded border border-primary-700/70 bg-primary-900/60 px-2 py-1 text-primary-100">Mode: Manual</span>
              <span id="status-last-event" class="rounded border border-neutral-700 bg-neutral-900 px-2 py-1 text-neutral-200">Last: –</span>
            </div>
          </div>
          <div class="grid gap-4 md:grid-cols-4 md:items-end">
            <div class="space-y-2 md:col-span-2">
              <p class="text-[11px] uppercase tracking-[0.16em] text-neutral-400">Modes</p>
              <div class="flex flex-wrap items-center gap-4 text-sm">
                <label class="flex items-center gap-2"><input type="radio" name="mode" id="mode-director" value="director" class="h-4 w-4" />Director</label>
                <label class="flex items-center gap-2"><input type="radio" name="mode" id="mode-manual" value="manual" class="h-4 w-4" checked />Manual</label>
              </div>
              <div class="flex flex-wrap gap-2 text-sm">
                <button id="init-btn" class="rounded border border-primary-700 bg-primary-900 px-3 py-2 text-primary-50 hover:border-primary-500">Init</button>
                <button id="destroy-btn" class="rounded border border-neutral-700 bg-neutral-900 px-3 py-2 text-neutral-100 hover:border-neutral-500">Destroy</button>
                <button id="restart-btn" class="rounded border border-amber-700 bg-amber-900 px-3 py-2 text-amber-50 hover:border-amber-500">Restart</button>
                <button id="clear-log-btn" class="rounded border border-neutral-700 px-3 py-2 text-neutral-100 hover:border-neutral-500">Clear Log</button>
              </div>
            </div>
            <div class="space-y-2">
              <p class="text-[11px] uppercase tracking-[0.16em] text-neutral-400">Manual section (optional)</p>
              <select id="section-select" class="w-full rounded border border-neutral-700 bg-neutral-900 px-3 py-2 text-sm text-neutral-50"></select>
              <p class="text-[11px] text-neutral-500">Manual mode can instantiate a single section controller.</p>
            </div>
            <div class="space-y-2">
              <p class="text-[11px] uppercase tracking-[0.16em] text-neutral-400">Log</p>
              <label class="flex items-center gap-2 text-sm text-neutral-200">
                <input type="checkbox" id="auto-scroll" class="h-4 w-4" checked /> Auto-scroll log
              </label>
              <p id="wired-sections" class="text-[11px] text-neutral-500">Wired sections: none</p>
            </div>
          </div>
        </div>
      </header>

      <section class="mx-auto max-w-6xl px-4 py-6 space-y-8">
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-primary-200">Event Controls</h2>
            <span class="text-xs text-neutral-400">Buttons reflect EVENTS shape</span>
          </div>
          <div id="event-groups" class="grid gap-3 md:grid-cols-2"></div>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          <div class="space-y-4">
            <h3 class="text-sm font-semibold uppercase tracking-[0.14em] text-primary-200">Stage / DOM stubs</h3>
            <div class="space-y-4 rounded border border-neutral-800 bg-neutral-900 p-4">
              <div class="grid grid-cols-3 gap-2 text-[11px] text-neutral-400">
                <div id="bg-gel-0" class="bg-gel rounded border border-neutral-800 bg-neutral-800 px-2 py-3 text-center">bg-gel-0</div>
                <div id="bg-gel-1" class="bg-gel rounded border border-neutral-800 bg-neutral-800 px-2 py-3 text-center">bg-gel-1</div>
                <div id="bg-gel-2" class="bg-gel rounded border border-neutral-800 bg-neutral-800 px-2 py-3 text-center">bg-gel-2</div>
              </div>

              <div id="overlay-view" class="relative h-40 rounded border border-neutral-800 bg-neutral-800">
                <div id="sizzle-background" class="absolute inset-0 grid place-items-center bg-neutral-900">
                  <span class="text-[11px] text-neutral-500">#sizzle-background (video stub)</span>
                  <video muted playsinline preload="none" class="hidden" aria-label="background video"></video>
                </div>
                <span class="absolute left-2 top-2 text-[11px] text-neutral-500">#overlay-view</span>
              </div>

              <div id="smooth-wrapper" class="rounded border border-neutral-800">
                <div id="smooth-content" class="space-y-3 p-4">
                  <section id="hero" class="rounded border border-primary-800/50 bg-primary-950/40 p-4">
                    <p class="text-[11px] uppercase tracking-[0.16em] text-primary-300">#hero</p>
                    <div class="text-sm text-primary-50">Hero stub content for animation hooks.</div>
                  </section>
                  <section id="bio" class="rounded border border-accent-800/50 bg-neutral-900 p-4">
                    <p class="text-[11px] uppercase tracking-[0.16em] text-accent-200">#bio</p>
                    <div class="text-sm text-neutral-100">Bio stub content for animation hooks.</div>
                  </section>
                </div>
              </div>
            </div>
          </div>

          <div class="space-y-4">
            <h3 class="text-sm font-semibold uppercase tracking-[0.14em] text-primary-200">Event Log</h3>
            <div class="flex min-h-[24rem] flex-col rounded border border-neutral-800 bg-neutral-900 p-4">
              <div class="mb-3 flex items-center justify-between text-xs text-neutral-400">
                <span id="log-summary">0 events</span>
                <span id="active-mode" class="rounded border border-neutral-700 bg-neutral-800 px-2 py-1 text-neutral-200">Bus: idle</span>
              </div>
              <ol id="event-log" class="flex-1 space-y-2 overflow-auto text-xs text-neutral-200" aria-live="polite"></ol>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
