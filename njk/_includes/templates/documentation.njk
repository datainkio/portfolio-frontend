---
bodyClasses: "text-neutral-900 sm:grid sm:grid-cols-12 gap-8 lg:gap-12"
sidebarBeforeClasses: "sm:col-span-3"
mainClasses: "col-span-6 mx-auto px-4"
sidebarAfterClasses: "sm:col-span-3"
contentClasses: "prose lg:prose-lg max-w-none"
---
{% extends "templates/base.njk" %}
{% import "organisms/navigation/tree-nav.njk" as treeNav %}
{% if collections is defined and collections.all is defined %}
  {% set aboutNav = collections.all | eleventyNavigation("About") %}
{% else %}
  {% set aboutNav = [] %}
{% endif %}

{% block sidebar_before %}
  <aside class="sidebar {{ sidebarBeforeClasses }}">
    {{ treeNav.render({ nav: aboutNav, currentUrl: page.url, ariaLabel: "About navigation" }) }}
  </aside>
{% endblock %}