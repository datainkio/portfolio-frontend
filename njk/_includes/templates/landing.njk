{% extends "layouts/base.njk" %}

{% block content %}
  <section class="text-center py-20 bg-white">
    <h1 class="text-5xl font-bold mb-4">{{ title }}</h1>
    <p class="text-xl text-gray-700 mb-8">{{ subtitle }}</p>
    <a href="{{ callToAction.url }}" class="bg-blue-500 text-white px-6 py-3 rounded-sm hover:bg-blue-600">
      {{ callToAction.text }}
    </a>
  </section>

  <section class="py-16">
    {{ content | safe }}
  </section>
{% endblock %}
