{% import "organisms/SitePreloader.njk" as Preloader %}
<!DOCTYPE html>
<html lang="en">
{% include "templates/partials/head.njk" %}
  
  {# 
  TODO: Confirm that setting aria-busy="true" on main is appropriate for
  indicating loading state during preloader sequence.

  GSAP Animation System Integration
  
  REQUIRED ELEMENT IDs FOR ANIMATION CONTROLLERS:
  - id="main-header" : Required by js/choreography/sections/Hero.js
  - id="work"        : Required by js/choreography/sections/Work.js  
  - id="biography"   : Required by js/choreography/sections/Biography.js
  
  DO NOT MODIFY these IDs without updating corresponding animation controllers
  Animation system depends on specific DOM structure and element targeting
  
  SCROLLSMOOTHER INTEGRATION:
  - Main content wrapper must maintain scroll context
  - Section elements require data-scroll attributes for ScrollTrigger
  - CSS transforms may interfere with animation timelines
  
  DESIGN TOKEN DEPENDENCIES:
  - Animation values sync from Figma design tokens
  - CSS custom properties used for timing and easing
  - Maintain --animation-* custom properties in styles/
  #}
  
  <body class="{{ bodyClasses | default('') }}">
    {% include "templates/partials/gtm-noscript.njk" %}
    {{ Preloader.render({ kind: "spinner", message: "Preparing the experience…" }) }}
    {% import "organisms/header/global-header.njk" as header %}
    {% import "organisms/footer/global-footer.njk" as footer %}
    {% import "atoms/gel.njk" as gelAtom %}
    {% import "molecules/background/video.njk" as background %}
    {{ header.render({ classes: "global-header fixed top-0 left-0 w-full z-20" }) }}

    {{ background.render({
      id:"sizzle-background",
      videoSrc: "/assets/video/sizzle.mp4",
      classes: "fixed inset-0 -z-10 pointer-events-none",
      defer: false,
      preload: "metadata"
    }) }}
      
    {{ gelAtom.render({ id: 'bg-gel-0', color: 'bg-gel-primary' }) }}
    {# Wrapping content with the smooth-wrapper and smooth-content divs for ScrollSmoother #}
    <div id="smooth-wrapper" class="{{ mainClasses }}">
      <div id="smooth-content" class="{{ contentClasses }}">
        <main id="page-main" aria-busy="true">
          {% block content %}
            {% if content %}
              {{ content | safe }}
            {% else %}
              {% loremPars 3 %}
            {% endif %}
          {% endblock %}
        </main>
        {{ footer.render({ classes: "global-footer py-8 px-4 text-center text-sm text-gray-500" }) }}
      </div>
    </div>
    <script type="module" src="/assets/js/preloader.js" defer></script>
  </body>
</html>