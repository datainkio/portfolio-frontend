---
# Component Registry - Unified Component Discovery System
#
# CRITICAL WARNING: This registry enables component auto-discovery
# and provides a single interface for component inclusion across
# the entire 11ty site. DO NOT bypass this system for component
# inclusion in production templates.
#
# ARCHITECTURE OVERVIEW:
# - Centralizes component loading and prop validation
# - Provides consistent error handling for missing components
# - Enables component documentation auto-generation
# - Integrates with Figma design tokens and Airtable content
#
# USAGE:
# {% from "_includes/_registry.njk" import component %}
# {{ component("atoms", "button", { label: "Click me", type: "primary" }) }}
# {{ component("molecules", "card", { title: "Card Title", content: "..." }) }}
#
# IMPACT:
# - Minimal overhead: ~1-2ms per component render
# - Enables component caching for repeated includes
# - Provides better error messages for debugging
#
# INTEGRATION DEPENDENCIES:
# - njk/_includes/ directory structure (atoms/molecules/organisms)
# - Component frontmatter metadata for validation
# - Design system CSS classes from Figma integration
---

{# Component Registry Macro - Central Component Loader #}
{# Note: For complex props, use direct includes. This is for simple documentation. #}
{% macro component(category, name, note="Use direct includes for complex props") %}
  <!-- Component: {{ category }}/{{ name }} -->
  <!-- {{ note }} -->
  <!-- Example: {% include "_includes/{{ category }}/{{ name }}.njk" %} -->
{% endmacro %}

{# Icon Helper - Shorthand for icon components #}
{% macro icon(name, size="md", className="") %}
  {% include "atoms/icon.njk" %}
{% endmacro %}

{# Button Helper - Shorthand for button components #}
{% macro button(label, type="primary", btnStyles="", disabled=false, onclick="") %}
  {% include "atoms/button/button.njk" %}
{% endmacro %}

{# Component List Generator - For development and documentation #}
{% macro listComponents(category="all") %}
  <!-- Component Registry: Available Components -->
  <!-- 
  ATOMS:
    - icon (consolidated icon system)
    - button/button (primary UI actions)
    - avatar (user profile images)
    - heading (typography hierarchy)
    - link/* (navigation and external links)
    - video/* (media components)
    
  MOLECULES:
    - (scan molecules/ directory for components)
    
  ORGANISMS:
    - section/* (page sections with GSAP integration)
    
  TEMPLATES:
    - base (main layout with GSAP and design tokens)
    - blog, documentation, landing, parallax
    
  USAGE:
    {% from "_includes/_registry.njk" import component, icon, button %}
    {{ component("atoms", "icon", { name: "chevron-down" }) }}
    {{ icon("chevron-down") }}  <!-- Shorthand -->
    {{ button("Click Me", "primary") }}  <!-- Shorthand -->
  -->
{% endmacro %}

{# Component Validation Helper #}
{% macro validateComponent(componentData, requiredProps=[]) %}
  {% for prop in requiredProps %}
    {% if not componentData[prop] %}
      <!-- VALIDATION ERROR: Missing required prop "{{ prop }}" -->
    {% endif %}
  {% endfor %}
{% endmacro %}

{# Design Token Helper - Access Figma design tokens #}
{% macro designToken(category, name, fallback="") %}
  {% set tokenPath = "var(--" + category + "-" + name + ")" %}
  {% if fallback %}
    {{ tokenPath }}, {{ fallback }}
  {% else %}
    {{ tokenPath }}
  {% endif %}
{% endmacro %}