{#
Primary Navigation Molecule
CRITICAL: eleventyNavigation plugin MUST be configured in eleventy.config.js
Dependencies: 
- Navigation items MUST have proper frontmatter with eleventyNavigation keys
- Integrates with GSAP animations in js/choreography/sections/Work.js
- Header animations in js/choreography/sections/Hero.js expect this DOM structure
#}

<ul class="primary-nav flex flex-row gap-4" role="list">
  {%- for entry in collections.all | eleventyNavigation %}
    <li class="nav-item">
      {% include "atoms/link/nav-link.njk" %}
      
      {# Dropdown for child navigation #}
      {% if entry.children and entry.children.length > 0 %}
        <ul class="dropdown-menu absolute top-full left-0 bg-neutral-900 border border-neutral-700 rounded-md shadow-lg py-2 min-w-48 z-50 hidden group-hover:block" role="list">
          {% for child in entry.children %}
            <li class="dropdown-item">
              {% set entry = child %}
              {% include "atoms/link/nav-link.njk" %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </li>
  {%- endfor %}
</ul>