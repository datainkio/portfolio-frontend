{% import "atoms/video/video.njk" as videoAtom %}

{% macro render(params = {}) %}
  {%- set bgID = params.id | default('sizzle-background') -%}
  {%- set containerClasses = params.classes | default('fixed inset-0 -z-10 pointer-events-none overflow-hidden') -%}
  <div
    id="{{ bgID }}"
    class="{{ containerClasses }}"
    aria-hidden="true"
  >
    {{ videoAtom.render({
      src: params.videoSrc,
      autoplay: params.autoplay | default(true),
      loop: params.loop | default(true),
      muted: params.muted | default(true),
      playsInline: params.playsInline | default(true),
      preload: params.preload | default("metadata"),
      className: "w-full h-dvh md:h-full object-cover z-0"
    }) }}
    <div class="absolute inset-0 bg-pixelator opacity-60 pointer-events-none z-10"></div>
  </div>
{% endmacro %}
