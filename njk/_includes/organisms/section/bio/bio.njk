{% macro render(params = {}) %}
    {%- set sectionId = params.id | default("bio") -%}
    {%- set classes = params.classes | default("relative z-10 col-start-3 col-end-9 p-4 mb-48 text-neutral-100") -%}
    {%- set heading = params.heading | default("I am a creative technologist.") -%}
    {%- set subheading = params.subheading | default("I believe in the power of design to create a more just, informed, and compassionate world.") -%}
    {%- set body = params.body | default("In my work I often find myself asking, \"What matters here?\" Is it the story we want to tell? The emotions we want to evoke? The actions we want to inspire? By focusing on what truly matters, I create experiences that are not only visually stunning but also deeply meaningful and impactful.") -%}

    {# Biography section - GSAP Biography Controller Target #}
    <section class="{{ classes }}" id="{{ sectionId }}" data-scroll-section>
        <header>
            <h2>{{ heading }}</h2>
            <p class="text-2xl">{{ subheading }}</p>
        </header>
        <p>{{ body }}</p>
    </section>
{% endmacro %}