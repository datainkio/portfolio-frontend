{# Work organized by category #}
{% import "molecules/card/category.njk" as categoryCard %}

<section class="relative z-10 col-start-3 col-end-12 mb-48" data-scroll-section>
  <ul
    id="work"
    class="flex flex-col gap-48 relative text-neutral-100 bg-neutral- sm:mx-6 md:mx-8 lg:mx-auto "
  >
    {% for category in collections.ia %}
      <li>{{ categoryCard.render({ category: category, collections: collections }) }}</li>
    {% endfor %}
  </ul>
</section>