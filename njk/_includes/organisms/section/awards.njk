{% macro render(params = {}) %}
  {%- set awards = params.awards
    | default([]) -%}
<section id="{{ params.id | default('awards') }}" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  {% if awards | length %}
    <ul class="awards-list grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-12 gap-6">
      {% for award in awards %}
        {% set logo = award.organization.logo.asset.url
          | default(award.logo.asset.url)
          | default(award.logo)
          | default('/assets/images/logos/default.svg') %}
        <li class="awards-list__item">
          <img
            src="{{ logo }}"
            alt="{{ award.organization.name | default('Organization') }}"
            class="awards-list__logo"
            loading="lazy"
            decoding="async"
          />
          <span class="awards-list__title">
            {{ award.title | default(award.name) | default('Untitled award') }}
          </span>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="awards-list__empty">No awards found.</p>
  {% endif %}
</section>
{% endmacro %}