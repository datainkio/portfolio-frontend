{% macro render(params = {}) %}
  {%- set projects = params.projects
    | default([]) -%}
<section id="{{ params.id | default('projects') }}" class="{{ params.classes | default('') }} projects-section">
  {% if projects | length %}
    <ul class="projects-list grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-12 gap-6">
      {% for project in projects %}
        <li class="projects-list__item">
          <span class="projects-list__title">
            {{ project.title | default(project.name) | default('Untitled project') }}
          </span>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="projects-list__empty">No projects found.</p>
  {% endif %}
</section>
{% endmacro %}