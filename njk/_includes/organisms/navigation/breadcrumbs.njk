{% macro render(params = {}) %}
	{%- set currentKey = params.key or eleventyNavigation.key -%}
	{%- set navSource = params.nav or collections.all -%}
	{%- set includeHome = params.includeHome if params.includeHome is defined else true -%}
	{%- set homeLabel = params.homeLabel or site.siteName or "Home" -%}

	{%- if not currentKey or not navSource -%}
		{%- set ancestry = [] -%}
	{%- else -%}
		{%- set ancestry = navSource | eleventyNavigationBreadcrumb(currentKey) -%}
	{%- endif -%}

	{%- set showHome = includeHome and page.url != "/" -%}
	{%- set hasCrumbs = (ancestry and ancestry | length) or showHome -%}

	{%- if hasCrumbs -%}
	<nav class="px-6 py-3 text-sm text-neutral-500 {{ params.classes }}" aria-label="Breadcrumb">
		<ol class="flex flex-wrap items-center gap-2">
			{%- if showHome -%}
				<li class="flex items-center gap-2">
					<a href="/" class="hover:text-neutral-900 transition-colors">{{ homeLabel }}</a>
					{%- if ancestry and ancestry | length -%}
						<span aria-hidden="true" class="text-neutral-400">/</span>
					{%- endif -%}
				</li>
			{%- endif -%}

			{%- for crumb in ancestry %}
				{%- set isLast = loop.last -%}
				<li class="flex items-center gap-2">
					{%- if not isLast -%}
						<a href="{{ crumb.url }}" class="hover:text-neutral-900 transition-colors">
							{{ crumb.title or crumb.key }}
						</a>
						<span aria-hidden="true" class="text-neutral-400">/</span>
					{%- else -%}
						<span class="text-neutral-900 font-semibold" aria-current="page">
							{{ crumb.title or crumb.key }}
						</span>
					{%- endif -%}
				</li>
			{%- endfor %}
		</ol>
	</nav>
	{%- endif -%}
{% endmacro %}