{% macro render(params = {}) %}
  {%- set items = params.items | default(skipLinks | default([])) -%}

  {%- if items and items | length -%}
    <nav class="skip-links sr-only focus-within:not-sr-only fixed top-4 left-4 z-50" aria-label="Skip links">
      <ul class="flex flex-col gap-2" role="list">
        {%- for id in items -%}
          <li>
            <a class="inline-flex rounded bg-neutral-900 px-3 py-2 text-sm font-medium text-white shadow focus:outline-none focus:ring-2 focus:ring-primary-500"
               href="#{{ id }}">
              Skip to {{ id | replace("-", " ") | capitalize }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}
{% endmacro %}