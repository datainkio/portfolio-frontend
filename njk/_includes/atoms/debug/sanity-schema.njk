{% macro render(params = {}) %}
  {# Displays field keys and sample values from the first item in a Sanity collection #}
  {% set collection = params.collection | default([]) %}
  {% set title = params.title | default('Schema Preview') %}
  {% set sample = collection | first %}
  {% if sample and sample.data is defined %}
    {% set record = sample.data %}
  {% else %}
    {% set record = sample %}
  {% endif %}
  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="text-lg font-semibold">{{ title }}</h2>
    {% if record %}
      <p class="mt-2 text-sm text-neutral-400">Showing fields from the first document to infer the schema.</p>
      <dl class="mt-4 grid grid-cols-1 gap-3 text-sm">
        {% for key, value in record %}
          <div class="rounded-lg bg-neutral-800 px-4 py-3">
            <dt class="text-neutral-400">{{ key }}</dt>
            <dd class="text-neutral-300 break-words">{{ value | dump }}</dd>
          </div>
        {% endfor %}
      </dl>
    {% else %}
      <p class="mt-2 text-sm text-neutral-400">No documents available to display schema.</p>
    {% endif %}
  </section>
{% endmacro %}
