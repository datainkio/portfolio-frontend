{#
/**
 * Video Atom
 * 
 * Basic video element with background video defaults.
 * 
 * @param {string} src - Video source URL (default: imgur sizzle.mp4)
 * @param {boolean} autoplay - Auto-play on load (default: false)
 * @param {boolean} loop - Loop video (default: false)
 * @param {boolean} muted - Mute audio (default: false)
 * @param {boolean} playsInline - Play inline on mobile (default: false)
 * @param {string} poster - Poster image URL (optional)
 * @param {string} className - Additional CSS classes (optional)
 * 
 * USAGE:
 * {% import "atoms/video/video.njk" as video %}
 * {{ video.render() }}
 * {{ video.render({ src: "/assets/video/custom.mp4", autoplay: true }) }}
 */
#}

{% macro render(params = {}) %}
  {%- set videoSrc = params.src | default('https://imgur.com/2cSaKIt.mp4') -%}
  {%- set videoAutoplay = params.autoplay | default(false) -%}
  {%- set videoLoop = params.loop | default(false) -%}
  {%- set videoMuted = params.muted | default(false) -%}
  {%- set videoPlaysInline = params.playsInline | default(false) -%}

  <video
    src="{{ videoSrc }}"
    {%- if videoAutoplay %} autoplay{% endif %}
    {%- if videoLoop %} loop{% endif %}
    {%- if videoMuted %} muted{% endif %}
    {%- if videoPlaysInline %} playsinline{% endif %}
    {%- if params.poster %} poster="{{ params.poster }}"{% endif %}
    {%- if params.className %} class="{{ params.className }}"{% endif %}>
    Your browser does not support the video tag.
  </video>
{% endmacro %}