{% set level = level | default(1) %} {# Use explicit tags to keep Prettier happy
while retaining a safe fallback #} {% if level == 1 %}
<h1 class="{{ class | default('') }}">{{ text | default('') }}</h1>
{% elif level == 2 %}
<h2 class="{{ class | default('') }}">{{ text | default('') }}</h2>
{% elif level == 3 %}
<h3 class="{{ class | default('') }}">{{ text | default('') }}</h3>
{% elif level == 4 %}
<h4 class="{{ class | default('') }}">{{ text | default('') }}</h4>
{% elif level == 5 %}
<h5 class="{{ class | default('') }}">{{ text | default('') }}</h5>
{% elif level == 6 %}
<h6 class="{{ class | default('') }}">{{ text | default('') }}</h6>
{% else %}
<p class="{{ class | default('') }}">
  {{ text | default('Invalid heading level') }}
</p>
{% endif %}
