{# Provide import map so raw ESM (no bundle) can resolve scoped packages in the browser #}
{% if runtime.bundleJs == false %}
  <script type="importmap">
    { "imports": { "@datainkio/lumberjack": "/assets/js/utils/lumberjack/index.js" } }
  </script>
{% endif %}

<script>
  window.__enableChoreography = {% if enableChoreography %}
    true
  {% else %}
    false
  {% endif %};
  if (!window.__enableChoreography) {
    window.addEventListener("DOMContentLoaded", () => window.dispatchEvent(new Event("director:ready")), {once: true});
  }
</script>

{# BUNDLE OR NO BUNDLE #}
{% if enableChoreography %}
  {% if runtime.bundleJs %}
    <script type="module">
      import ('/assets/js/choreography/bundle.js').catch(() => import ('/assets/js/choreography/AnimationDirector.js'));
    </script>
  {% else %}
    <script type="module">
      import ('/assets/js/choreography/AnimationDirector.js');
    </script>
  {% endif %}
{% endif %}

{# PRELOADER SCRIPT #}
<script type="module">
  import {initPreloader} from "/assets/js/preloader/Preloader.js";

  void initPreloader();
</script>