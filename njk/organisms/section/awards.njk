{% macro render(params = {}) %}
  {%- set awards = params.awards
    | default([]) -%}
  <section id="{{ params.id | default('awards') }}" class="{{ params.classes | default('text-primary-100 h-dvh') }}">
    {% if awards | length %}
      <h2>{{ params.copy.heading }}</h2>
      <p>{{ params.copy.body }}</p>
      <ul class="awards-list grid grid-cols-6 gap-4">
        {% for award in awards %}
          {% set logo = award.organization.logo.asset.url
          | default(award.logo.asset.url)
          | default(award.logo)
          | default('/assets/images/logos/default.svg') %}
          <li class="awards-list__item">
            <img src="{{ logo }}" alt="{{ award.organization.name | default('Organization') }}: {{ award.title | default(award.name) | default('Untitled award') }}" class="awards-list__logo" loading="lazy" decoding="async"/>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p class="awards-list__empty">No awards found.</p>
    {% endif %}
  </section>
{% endmacro %}