{% macro render(params = {}) %}
  {% import "molecules/current-section-title.njk" as CurrentSectionTitle %}
  {%- set sectionId = params.id | default("intro") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading -%}
  {%- set subheading = params.copy.subheading -%}
  {%- set body = params.copy.body -%}
  {%- set order = params.order | default("") -%}

  {# Biography section #}
  <section class="bg-primary-800 relative z-10 col-span-full prose prose-invert [&_p]:col-span-full max-w-none prose-p:col-span-full {{ classes }}" id="{{ sectionId }}" data-scroll-section>
    <header class="col-span-full space-y-4" data-bio-el="header">
      <div class="text-sm sticky top-8 bg-primary-800 z-10" data-bio-el="context">
        {{ CurrentSectionTitle.render({title: sectionId , count: order}) }}
      </div>
      <h2 data-bio-el="heading">{{ heading }}</h2>
      <p class="text-2xl" data-bio-el="subheading">{{ subheading }}</p>
    </header>
    {{ body | safe }}
  </section>
{% endmacro %}