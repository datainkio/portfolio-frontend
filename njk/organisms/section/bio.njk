{% macro render(params = {}) %}
  {% import "molecules/current-section-title.njk" as CurrentSectionTitle %}
  {%- set sectionId = params.id | default("bio") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading -%}
  {%- set subheading = params.copy.subheading -%}
  {%- set body = params.copy.body -%}

  {# Biography section - GSAP Biography Controller Target #}
  <section class="relative z-10 col-span-full text-neutral-100 space-y-6" id="{{ sectionId }}" data-scroll-section>
    <h2>{{ heading }}</h2>
    <p class="text-2xl">{{ subheading }}</p>
    {{ CurrentSectionTitle.render({classes: "m-0"}) }}
  </section>
{% endmacro %}