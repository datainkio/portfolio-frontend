{% macro render(params = {}) %}
  {% import "molecules/current-section-title.njk" as CurrentSectionTitle %}
  {%- set sectionId = params.id | default("hero") -%}
  {%- set tagline = params.tagline | default(title) -%}
  {%- set rulerOptions = params.ruler | default({}) -%}
  {%- set classes = params.classes | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}

  {# Landing view - GSAP Hero Controller Target #}
  <section id="{{ sectionId }}" class="relative z-10 col-span-full w-full overflow-hidden h-dvh flex items-center {{ classes }}" aria-labelledby="{{ headingId }}" data-scroll-section>
    <h1 id="{{ headingId }}" data-hero-el="tagline" class="z-10 text-6xl sm:text-7xl md:text-8xl lg:text-9xl leading-12 sm:leading-14 md:leading-16 lg:leading-28
                tracking-tighter uppercase font-display text-primary-100">
      {{ tagline }}
    </h1>
  </section>
{% endmacro %}