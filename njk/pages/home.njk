{% import "organisms/SitePreloader.njk" as Preloader %}
{% import "organisms/header/global-header.njk" as Header %}
{% import "organisms/footer/global-footer.njk" as Footer %}
{% import "molecules/background/video-background.njk" as Background %}
{%- set rulerOptions = params.rulerOptions | default({}) -%}
{%- set contentClasses = params.contentClasses | default('min-h-screen') -%}
<!DOCTYPE html>
<html lang="en">
    {% include "templates/partials/head.njk" %}
    <body class="{{ bodyClasses | default('') }}">
        {% include "templates/partials/gtm-noscript.njk" %}
        {{ Preloader.render({ kind: "spinner", message: "Preparing the experience…" }) }}
        {{ Header.render({ classes: "global-header fixed top-0 left-0 w-full z-20" }) }}
        {{ Background.render({
  id:"sizzle-background",
  videoSrc: hero.videoSrc,

  classes: "fixed inset-0 -z-10 pointer-events-none overflow-hidden gsap-element gsap-fade",
  defer: false,
  preload: "none",
  autoPlay: true
  }) }}
        {# Wrapping content with the smooth-wrapper and smooth-content divs for ScrollSmoother #}
        <div id="smooth-wrapper" class="{{ mainClasses }}">
            <div id="smooth-content" class="{{ contentClasses }}">
                <main id="page-main" aria-busy="true">

                    {% import "organisms/section/hero.njk" as heroSection %}
                    {% import "organisms/section/bio/bio.njk" as bioSection %}
                    {% import "organisms/section/recognition/logos.njk" as awards %}
                    {% import "organisms/section/projects.njk" as projects %}
                    {# Note that content values are set in frontmatter #}
                    {{ heroSection.render( { id: "hero", tagline: hero.tagline }) }}
                    {{ bioSection.render({id: "bio", copy: value, classes: "relative z-10 col-start-3 col-end-9 p-4 mb-48 bg-primary-100 text-primary-950"}) }}
                    {{ awards.render({ id: "awards", copy: recognition, awards: collections.awards, classes: "bg-white p-4 mb-48" }) }}
                    {{ projects.render({ id: "projects", projects: collections.projects, classes:"bg-white p-4 mb-48" }) }}
                </main>
                {{ Footer.render({ classes: "global-footer py-8 px-4 text-center text-sm text-primary-200 bg-primary-950" }) }}
            </div>
        </div>
        {% include "templates/partials/choreography-script.njk" %}
    </body>
</html>