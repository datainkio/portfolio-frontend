{# FUNCTIONALITY IMPORTS #}
{% import "organisms/SitePreloader.njk" as Preloader %}
{% import "organisms/header/global-header.njk" as Header %}
{% import "organisms/footer/global-footer.njk" as Footer %}

{# UX IMPORTS #}
{% import "molecules/background/sizzle-background.njk" as Background %}

{# SECTION CONTENT #}
{% import "organisms/section/hero.njk" as heroSection %}
{% import "organisms/section/bio.njk" as bioSection %}
{% import "organisms/section/awards.njk" as awardsSection %}
{% import "organisms/section/work.njk" as projectsSection %}
{% import "organisms/section/organizations.njk" as organizationsSection %}

{# SECTION STYLING #}
{% set sharedClasses = "p-4 sm:p-8 md:p-16 lg:p-32" %}
{# Note that content values are set in frontmatter #}
<!DOCTYPE html>
<html lang="en" class="bg-slate-950">
    {% include "templates/partials/head.njk" %}
    <body>
        {% include "templates/partials/gtm-noscript.njk" %}
        {{ Preloader.render({ kind: "spinner", message: "Lubricating the framistan…" }) }}
        {{ Header.render() }}
        {{ Background.render({
            id:"sizzle-background",
            videoSrc: hero.videoSrc,
            defer: false,
            preload: "none",
            autoPlay: true
            }) }}
        {# Wrapping content with the smooth-wrapper and smooth-content divs for ScrollSmoother #}
        <div id="smooth-wrapper">
            <div id="smooth-content">
                <main id="page-main" aria-busy="true" class="space-y-48 grid grid-cols-12 text-neutral-100">
                    {# Note that content values are set in frontmatter #}
                    {# The id param has a matching value in SELECTORS.js for consistency w/choreography #}
                    {{ heroSection.render( { id: "hero", tagline: hero.tagline, classes: sharedClasses }) }}
                    {{ bioSection.render({id: "introduction", copy: value, order: "1/4", classes: sharedClasses}) }}
                    {{ awardsSection.render({ id: "recognition", copy: recognition, awards: collections.awards, order: "2/4", classes: sharedClasses }) }}
                    {{ projectsSection.render({ id: "work", projects: collections.projects, classes: sharedClasses, order: "3/4" }) }}
                {{ organizationsSection.render({ id: "organizations", organizations: collections.organizations, classes: sharedClasses, order: "4/4" }) }}
                </main>
            {{ Footer.render() }}
        </div>
        </div>
    {% include "templates/partials/choreography-script.njk" %}
</body></html>