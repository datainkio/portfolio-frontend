{% extends "templates/landing.njk" %}
{% block content %}
    {{ tagline | default("no tagline defined") }}
    {{ collections.landing[0].tagline }}
    <section class="space-y-4">
        <h2 class="text-2xl font-semibold">Collections</h2>
        <ul class="space-y-1">
            {% for name, items in collections %}
                <li>
                    <strong>{{ name }}</strong>
                    {% if items and items.length is not undefined %}
                        <span>({{ items.length }})</span>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </section>
{% endblock %}