---
layout: null
permalink: /playground/hero/
title: 'Hero IxD Playground'
metaDescription: 'Isolated hero choreography harness for intro/outro tuning.'
scripts: >
  <script type="module" src="/assets/js/hero-playground.js"></script>
---
{% import "organisms/section/hero.njk" as HeroSection %}
<!DOCTYPE html>
<html lang="en">
  {% include "templates/partials/head.njk" %}
  <body class="bg-neutral-950 text-neutral-50">
    <main class="min-h-screen">
      <header class="sticky top-0 z-30 border-b border-neutral-800 bg-neutral-950/90 backdrop-blur">
        <div class="mx-auto flex max-w-5xl flex-col gap-4 px-4 py-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p class="text-[11px] uppercase tracking-[0.18em] text-primary-300">Hero IxD Playground</p>
              <p class="text-sm text-neutral-300">Trigger hero intro/outro repeatedly to tune interaction feel.</p>
            </div>
            <div class="flex flex-wrap items-center gap-2 text-xs text-neutral-300">
              <span id="status-active" class="rounded border border-primary-700/70 bg-primary-900/60 px-2 py-1 text-primary-100">Idle</span>
              <span id="status-last" class="rounded border border-neutral-700 bg-neutral-900 px-2 py-1 text-neutral-200">Last: –</span>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-2 text-sm">
            <button id="init-btn" class="rounded border border-primary-700 bg-primary-900 px-3 py-2 text-primary-50 hover:border-primary-500">Init Hero</button>
            <button id="destroy-btn" class="rounded border border-neutral-700 bg-neutral-900 px-3 py-2 text-neutral-100 hover:border-neutral-500">Destroy</button>
            <button id="restart-btn" class="rounded border border-amber-700 bg-amber-900 px-3 py-2 text-amber-50 hover:border-amber-500">Restart</button>
            <button id="clear-log-btn" class="rounded border border-neutral-700 px-3 py-2 text-neutral-100 hover:border-neutral-500">Clear Log</button>
            <button id="start-intro" class="rounded border border-emerald-700 bg-emerald-900 px-3 py-2 text-emerald-50 hover:border-emerald-500">Start Intro</button>
            <button id="start-outro" class="rounded border border-rose-700 bg-rose-900 px-3 py-2 text-rose-50 hover:border-rose-500">Start Outro</button>
            <span id="lifecycle-status" class="text-xs text-neutral-400">Select Init to begin</span>
          </div>
          <label class="flex items-center gap-2 text-xs text-neutral-300">
            <input type="checkbox" id="auto-scroll" class="h-4 w-4" checked /> Auto-scroll log
          </label>
        </div>
      </header>

      <section class="mx-auto max-w-5xl px-4 py-6 space-y-6">
        <div class="space-y-3">
          <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-primary-200">Stage</h2>
          <div class="rounded border border-neutral-800 bg-neutral-900 p-4">
            <div id="hero-stage" class="relative grid min-h-[50vh] place-items-center overflow-hidden rounded border border-primary-800/50 bg-primary-950/30 p-6">
              {{ HeroSection.render({
                id: 'hero'
              }) }}
            </div>
          </div>
        </div>

        <div class="space-y-3">
          <h3 class="text-sm font-semibold uppercase tracking-[0.14em] text-primary-200">Event Log</h3>
          <div class="flex min-h-[18rem] flex-col rounded border border-neutral-800 bg-neutral-900 p-4">
            <div class="mb-3 flex items-center justify-between text-xs text-neutral-400">
              <span id="log-summary">0 events</span>
              <span id="active-mode" class="rounded border border-neutral-700 bg-neutral-800 px-2 py-1 text-neutral-200">Bus: idle</span>
            </div>
            <ol id="event-log" class="flex-1 space-y-2 overflow-auto text-xs text-neutral-200" aria-live="polite"></ol>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
