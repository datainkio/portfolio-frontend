{% macro render(params = {}) %}
  {%- set title = params.title | default("") -%}
  {%- set showTitle = params.showTitle | default(true) -%}
  {%- set image = params.image -%}
  {%- set url = params.url | default("") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set imageClasses = params.imageClasses | default("") -%}

  {%- set imageSrc = image and (image.src or image.url or image.asset.url or image) -%}
  {%- set imageAlt = image and image.alt or title -%}

  <article class="overflow-hidden {{ classes }}">
    {% if url %}
      <a href="{{ url }}" class="block h-full focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-900 focus-visible:ring-neutral-200">
      {% else %}
        <div class="block h-full">
        {% endif %}

        {% if imageSrc %}
          <figure class="aspect-square overflow-hidden">
            <img src="{{ imageSrc }}" alt="{{ imageAlt }}" class="h-full w-full object-contain {{ imageClasses }}" loading="lazy"/>
          </figure>
        {% endif %}
        <h3 class="text-base sm:text-lg font-semibold text-neutral-100">{{ title }}</h3>
        {% if url %}
        </a>
    {% else %}
      </div>
    {% endif %}
  </article>
{% endmacro %}