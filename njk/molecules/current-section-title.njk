{% macro render(params = {}) %}
  {%- set trackedSectionsSelector = params.trackedSectionsSelector | default("section[id]:not(#hero)") -%}
  <p data-current-section-marker data-tracked-sections-selector="{{ trackedSectionsSelector }}" role="status" aria-live="polite" aria-atomic="true" class="text-sm text-neutral-100 w-full z-20 pointer-events-none {{ params.classes | default(" ") }}">
    <span data-current-section-prefix>section</span>
    <span data-current-section-count>0 of 0</span>
    <span data-current-section-separator>:</span>
    <span data-current-section-title>none</span>
  </p>
{% endmacro %}