    %% Content Aggregation
    FEED }o--|| PROJECTS : "references"
    FEED }o--|| INSIGHTS : "references"
    
    %% Organizational Connections
    ROLES }o--o{ ORGANIZATIONS : "at"
    
    %% Self-referential
    IA ||--o{ IA : "parent"
