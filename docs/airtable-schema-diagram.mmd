    PROJECTS }o--o{ ACTIVITIES : "involves"
    PROJECTS }o--o{ AWARDS : "recognized-by"
    PROJECTS }o--|| IA : "categorized-as"
    
    %% Media Relationships
    GALLERIES ||--o{ IMAGES : "contains"
    PROJECTS ||--o{ IMAGES : "features"
