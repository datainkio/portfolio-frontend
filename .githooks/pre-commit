#!/bin/sh

# Gate frontend commits on AIX context freshness.
# This ensures that substantial frontend changes trigger a context review.

set -eu

resolve_node() {
  if command -v node >/dev/null 2>&1; then
    command -v node
    return 0
  fi

  for candidate in /opt/homebrew/bin/node /usr/local/bin/node; do
    if [ -x "$candidate" ]; then
      echo "$candidate"
      return 0
    fi
  done

  return 1
}

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$ROOT" ]; then
  exit 0
fi

# Expected layout: <workspace>/frontend and <workspace>/aix
AIX_ROOT="${AIX_ROOT:-"$ROOT/../aix"}"

if [ ! -d "$AIX_ROOT" ]; then
  echo "aix context gate: AIX repo not found at $AIX_ROOT (set AIX_ROOT to override); skipping"
  exit 0
fi

cd "$AIX_ROOT"

if [ -f "scripts/update-context-freshness.mjs" ]; then
  NODE_BIN="$(resolve_node || true)"
  if [ -z "$NODE_BIN" ]; then
    echo "frontend pre-commit: Node.js runtime not found." 1>&2
    echo "Install Node.js or expose it in PATH (e.g. /opt/homebrew/bin/node)." 1>&2
    exit 1
  fi

  "$NODE_BIN" scripts/update-context-freshness.mjs --fail-on-threshold
fi

exit 0
