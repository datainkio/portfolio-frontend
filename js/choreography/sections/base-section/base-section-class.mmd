classDiagram
    class BaseSection {
        <<abstract>>
        +string id
        +AnimationBus bus
        +ScrollSmoother smoother
        +HTMLElement element
        +Timeline timeline
        +boolean isIntroComplete
        +boolean isOutroComplete
        +boolean isScrollActive
        
        +constructor(sectionId, bus, smoother)
        +createIntro()* void
        +createOutro()* void
        +createScrollTriggers()* void
        +playIntro() Promise~void~
        +playOutro() Promise~void~
        +reset() void
        +destroy() void
    }
    
    class Hero {
        +HTMLElement titleElement
        +Timeline rollTimeline
        
        +constructor(bus, smoother)
        +createIntro() void
        +createScrollTriggers() void
    }
    
    class Work {
        +HTMLElement workElement
        
        +constructor(bus, smoother)
        +createIntro() void
        +createScrollTriggers() void
    }
    
    class Biography {
        +HTMLElement bioElement
        
        +constructor(bus, smoother)
        +createIntro() void
        +createScrollTriggers() void
    }
    
    class AnimationBus {
        <<external>>
        +on(event, callback) Function
        +emit(event, data) void
        +enableDebug(enabled) void
    }
    
    class Timeline {
        <<GSAP>>
        +paused boolean
        +restart() Timeline
        +reverse() Timeline
        +pause(time) Timeline
        +kill() void
        +then(callback) Promise
    }
    
    class ScrollSmoother {
        <<GSAP>>
        +create(config) ScrollSmoother
        +paused(value) ScrollSmoother
    }
    
    class ScrollTrigger {
        <<GSAP>>
        +create(config) ScrollTrigger
        +getAll() ScrollTrigger[]
        +kill() void
    }

    BaseSection <|-- Hero : extends
    BaseSection <|-- Work : extends
    BaseSection <|-- Biography : extends
    BaseSection o-- AnimationBus : uses
    BaseSection o-- ScrollSmoother : optional
    BaseSection *-- Timeline : creates
    BaseSection ..> ScrollTrigger : uses
    
    note for BaseSection "Foundation class providing standard\nlifecycle and event coordination.\nSubclasses override create* methods."
    
    note for Hero "Hero section with TextParty.roll intro\nand scroll-triggered reverse outro"
    
    note for Work "Work section with printer marks\nand fade-in intro animation"
    
    note for Biography "Biography section with list item\nstaggered reveal animations"
