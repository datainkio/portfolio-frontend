---
template:
  id: "templates.layouts.blog"
  name: "Blog Post Layout"
  type: "layout"
  status: "active"

source:
  path: "frontend/views/layouts/blog.njk"
  engine: "nunjucks"
  eleventyLayout: true

purpose:
  summary: "Blog post layout extending base.njk with article prose, publication date, and prev/next navigation."

data:
  expects:
    - "title"
    - "date"
    - "content"
    - "previousPost"
    - "nextPost"

tags:
  - "layout"
  - "blog"
  - "11ty"
---

{% extends "layouts/base.njk" %}

{% block content %}
  <article class="prose lg:prose-xl">
    <h1>{{ title }}</h1>
    <p class="text-sm text-gray-500">
      Published on {{ date | date("MMMM DD, YYYY") }}
    </p>
    {{ content | safe }}
  </article>

  <nav class="mt-8 flex justify-between">
    {% if previousPost %}
      <a href="{{ previousPost.url }}" class="text-blue-500 hover:underline">← {{ previousPost.title }}</a>
    {% endif %}
    {% if nextPost %}
      <a href="{{ nextPost.url }}" class="text-blue-500 hover:underline">{{ nextPost.title }} →</a>
    {% endif %}
  </nav>
{% endblock %}