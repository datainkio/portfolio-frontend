{% import "organisms/header/global-header.njk" as GlobalHeader with context %}
{% import "organisms/footer/global-footer.njk" as Footer with context %}
{% import "organisms/navigation/skip-links-nav.njk" as SkipLinks %}
{%- set brandLogoUrl = cms.siteSettings[0].brand.logo.asset.url if (cms and cms.siteSettings and cms.siteSettings[0] and cms.siteSettings[0].brand and cms.siteSettings[0].brand.logo and cms.siteSettings[0].brand.logo.asset) else "" -%}
{%- set brandLogoSvg = brandLogoUrl | inlineSvgFromUrl -%}
{%- set bodyClasses = {
  "base": "bg-white",
  "sm": "",
  "md": "",
  "lg": "",
  "xl": ""
} -%}
{%- set mainClasses = {
  "base": "grid grid-cols-12 w-full",
  "sm": "",
  "md": "",
  "lg": "",
  "xl": ""
} -%}
{%- set sidebarBeforeClasses = {
  "base": "",
  "sm": "",
  "md": "",
  "lg": "",
  "xl": ""
} -%}
{%- set sidebarAfterClasses = {
  "base": "",
  "sm": "",
  "md": "",
  "lg": "",
  "xl": ""
} -%}
<!DOCTYPE html>
<html lang="en">
  {% include "templates/partials/head.njk" %}
  {% block head %}{% endblock %}
  <body
    class="{{ bodyClasses | classes }}">
    {# GTM #}
    {% include "templates/partials/gtm-noscript.njk" %}
    {# SKIP LINKS #}
    {{ SkipLinks.render() }}
    {# GLOBAL PAGE HEADER #}
    {{ GlobalHeader.render({classes: 'font-display', logoSvg: brandLogoSvg}) }}
    {# MAIN CONTENT AREA #}
    <main class="{{ mainClasses | classes }}">
      {% if sidebar_before %}
        <aside class="{{ sidebarBeforeClasses | classes }}" data-scroll data-scroll-sticky data-scroll-target="main">
          {% block sidebar_before %}
            Hi there. This is the sidebar content. You can replace this with your own content or remove it if you don't need a
            sidebar.
          {% endblock %}
        </aside>
      {% endif %}
      {% block content %}
        {% if content %}
          {{ content | safe }}
        {% else %}
          {% loremPars 3 %}
        {% endif %}
      {% endblock %}
      {% if sidebar_after %}
        <aside class="{{ sidebarAfterClasses | classes }}" data-scroll data-scroll-sticky data-scroll-target="main">
          {% block sidebar_after %}
            Hi there. This is the sidebar content. You can replace this with your own content or remove it if you don't need a
            sidebar.
          {% endblock %}
        </aside>
      {% endif %}
    </main>
    {# GLOBAL PAGE FOOTER #}
    {{ Footer.render() }}
  </body>
</html>