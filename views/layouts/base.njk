---
template:
  id: "templates.layouts.base"
  name: "Base Layout"
  type: "layout"
  status: "active"

source:
  path: "frontend/views/layouts/base.njk"
  engine: "nunjucks"
  eleventyLayout: true

purpose:
  summary: "Root HTML document layout — head, body, global header/footer, skip links, GTM, and content/sidebar blocks."
  role: "Extended by all page-level layouts; controls CSS loading order, JS module loading, and global navigation."

data:
  expects:
    - "bodyClasses"
    - "mainClasses"
    - "breadcrumbKey"
    - "eleventyNavigation"
    - "collections.all"
  provides:
    - "content block"
    - "sidebar_before block"
    - "sidebar_after block"
    - "head block"

components:
  uses:
    - "organisms/header/global-header.njk"
    - "organisms/footer/global-footer.njk"
    - "organisms/navigation/skip-links-nav.njk"
    - "organisms/navigation/breadcrumbs-nav.njk"
    - "templates/partials/head.njk"
    - "templates/partials/gtm-noscript.njk"

agent:
  safeToEdit:
    - "frontmatter"
    - "CSS classes"
  doNotEdit:
    - "block names"
    - "script loading order"
  reviewTriggers:
    - "CSS loading order changes"
    - "JS module dependency changes"
    - "navigation organism changes"

tags:
  - "layout"
  - "base"
  - "11ty"
  - "nunjucks"
---

{% import "organisms/header/global-header.njk" as header with context %}
{% import "organisms/footer/global-footer.njk" as footer with context %}
{% import "organisms/navigation/skip-links-nav.njk" as skip_links %}
{% import "organisms/navigation/breadcrumbs-nav.njk" as breadcrumbs with context %}

<!DOCTYPE html>
<html lang="en">
  {% include "templates/partials/head.njk" %}
  {% block head %}{% endblock %}
  <body
    class="bg-primary-950 {{ bodyClasses }}" data-scroll-container>
    {# GTM #}
    {% include "templates/partials/gtm-noscript.njk" %}
    {# SKIP LINKS #}
    {{ skip_links.render() }}
    {# GLOBAL PAGE HEADER #}
    {{ header.render({classes: 'font-display'}) }}
    {# SIDEBAR #}
    {% block sidebar_before %}
      {% if sidebar_before %}
        {{ sidebar_before | safe }}
      {% endif %}
    {% endblock %}
    {# MAIN CONTENT AREA #}
    <main
      class="py-8 {{ mainClasses }}" data-scroll-container>
      {# BREADCRUMBS #}
      {{ breadcrumbs.render({ key: breadcrumbKey or (eleventyNavigation and eleventyNavigation.key), nav: collections.all, classes: 'col-span-full w-full' }) }}
      {% block content %}
        {% if content %}
          {{ content | safe }}
        {% else %}
          {% loremPars 3 %}
        {% endif %}
      {% endblock %}
    </main>
    {# SIDEBAR #}
    {% block sidebar_after %}
      {% if sidebar_after %}
        {{ sidebar_after | safe }}
      {% endif %}
    {% endblock %}
    {# GLOBAL PAGE FOOTER #}
    {{ footer.render() }}
  </body>
</html>