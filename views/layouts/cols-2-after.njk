---
template:
  id: "templates.layouts.cols-2-after"
  name: "2-Column Layout (Sidebar After)"
  type: "layout"
  status: "active"

source:
  path: "frontend/views/layouts/cols-2-after.njk"
  engine: "nunjucks"
  eleventyLayout: true

purpose:
  summary: "2-column layout extending base.njk with content on the left and a sidebar column on the right."

data:
  provides:
    - "content block"
    - "sidebar_after block"

tags:
  - "layout"
  - "2-column"
  - "11ty"
---

{% extends "./base.njk" %}
{% import "molecules/docs-nav/docs-nav.njk" as docsNav %}
{%- set bodyClasses = "grid grid-cols-12" -%}
{%- set mainClasses = "col-span-full w-full grid grid-cols-12" -%}
{%- set sidebarAfterClasses = "col-span-2" -%}
{% block content %}
  {% if content %}
    {{ content | safe }}
  {% else %}
    {% loremPars 3 %}
  {% endif %}
{% endblock %}
{% block sidebar_after %}
  {% if sidebar_after %}
    {{ sidebar_after | safe }}
  {% else %}
    {% loremPars 3 %}
  {% endif %}
{% endblock %}