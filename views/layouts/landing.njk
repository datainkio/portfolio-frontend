{% extends "./base.njk" %}
{% set navClasses = "text-neutral-200" %}
{% block content %}
  {% if title %}
    <h1 class="col-span-full px-4 text-8xl text-neutral-100 h-96 font-display bg-neutral-950 flex items-end">{{ title }}</h1>
    <section doc-abstract class="prose prose-lg px-4 col-span-full max-w-none">
      {{ body | safe }}
    </section>
  {% endif %}
  {% if content %}
    {{ content | safe }}
  {% elif not title %}
    {% loremPars 3 %}
  {% endif %}
{% endblock %}