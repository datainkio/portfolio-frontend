---
template:
  id: "templates.layouts.cols-3"
  name: "3-Column Layout"
  type: "layout"
  status: "active"

source:
  path: "frontend/views/layouts/cols-3.njk"
  engine: "nunjucks"
  eleventyLayout: true

purpose:
  summary: "3-column layout extending base.njk — sticky docs nav sidebars flanking a centred content area."

components:
  uses:
    - "molecules/docs-nav/docs-nav.njk"

tags:
  - "layout"
  - "3-column"
  - "docs"
  - "11ty"
---

{% extends "./base.njk" %}
{% import "molecules/docs-nav/docs-nav.njk" as docsNav %}
{%- set bodyClasses = "grid grid-cols-12" -%}
{%- set mainClasses = "col-span-8 col-start-3" -%}
{%- set sidebarBeforeClasses = "col-span-2" -%}
{%- set sidebarAfterClasses = "col-span-2" -%}

{% block sidebar_before %}
  <aside class="{{ sidebarBeforeClasses }}" data-scroll data-scroll-sticky data-scroll-target="main">
    {{ docsNav.render({ collections: collections, page: page }) }}
  </aside>
{% endblock %}

{% block content %}
  {% if content %}
    {{ content | safe }}
  {% else %}
    {% loremPars 3 %}
  {% endif %}
{% endblock %}

{% block sidebar_after %}
  <aside class="{{ sidebarAfterClasses }}" data-scroll data-scroll-sticky data-scroll-target="main">
    {% if sidebar_after %}
      {{ sidebar_after | safe }}
    {% else %}
      {% loremPars 3 %}
    {% endif %}
  </aside>
{% endblock %}