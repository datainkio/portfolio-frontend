{% macro render(params = {}) %}
  {% import "molecules/section-cap.njk" as SectionCap %}
  {% import "molecules/printmarks.njk" as PrintMarks %}
  {%- set sectionId = params.id | default("bio") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading -%}
  {%- set subheading = params.copy.subheading -%}
  {%- set body = params.copy.body -%}
  {%- set order = params.order | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}
  {%- set buildDate = params.buildDate -%}

  {%- set section = {
    "base": "relative h-dvh content-center text-white bg-black col-span-full prose max-w-4xl mx-auto"
  } %}
  {% set header = {
    "base": "col-span-full z-10 flex flex-wrap items-center [&>time]:ml-auto"
  } %}
  {%- set title = {
    "base": "basis-full px-10 font-display text-3xl",
    "sm": "sm:text-4xl"
  } %}
  {%- set copy = {
    "base": "basis-full px-10 mt-4 text-lg font-light columns-md",
    "sm": "sm:text-xl",
    "md": "md:text-2xl"
  } %}

  {# Biography section #}
  <section class="{{ section | classes }} {{ classes }}" id="{{ sectionId }}" aria-labelledby="{{ headingId }}" data-scroll-section>
    <header class="{{ header | classes }}" data-bio-el="header">
      {{ SectionCap.render({title: sectionId , count: order, buildDate: buildDate}) }}
      <h2 class="{{ title | classes }}" id="{{ headingId }}" data-bio-el="heading">{{ heading }}</h2>
      <p class="{{ copy | classes }}" data-bio-el="subheading">{{ subheading }}</p>
    </header>
  </section>
{% endmacro %}