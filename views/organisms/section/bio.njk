---
template:
  id: "templates.organisms.section.bio"
  name: "Bio Section"
  type: "organism"
  status: "active"

source:
  path: "frontend/views/organisms/section/bio.njk"
  engine: "nunjucks"

purpose:
  summary: "Homepage biography section — section header, bio copy, and print mark decoration."

data:
  expects:
    - "params.copy.heading"
    - "params.copy.subheading"
    - "params.copy.body"
    - "params.order"

components:
  uses:
    - "molecules/section-cap.njk"
    - "molecules/printmarks.njk"

tags:
  - "organism"
  - "section"
  - "bio"
  - "homepage"
---

{% macro render(params = {}) %}
  {% import "molecules/section-cap.njk" as SectionCap %}
  {% import "molecules/printmarks.njk" as PrintMarks %}
  {%- set sectionId = params.id | default("bio") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading -%}
  {%- set subheading = params.copy.subheading -%}
  {%- set body = params.copy.body -%}
  {%- set order = params.order | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}
  {%- set buildDate = params.buildDate -%}

  {# Biography section #}
  <section class="relative p-12 bg-white text-black col-span-full prose {{ classes }}" id="{{ sectionId }}" aria-labelledby="{{ headingId }}" data-scroll-section>
    {{ PrintMarks.render({classes: "inset-4"}) }}
    <header class="col-span-full z-10" data-bio-el="header">
      <div class="text-xs space-x-1 font-thin px-2 mt-4 flex items-center justify-between" data-bio-el="context">
        {{ SectionCap.render({title: sectionId , count: order, buildDate: buildDate}) }}
      </div>
      <h2 class="px-10 font-display text-3xl sm:text-4xl" id="{{ headingId }}" data-bio-el="heading">{{ heading }}</h2>
      <p class="px-10 mt-4 text-lg" data-bio-el="subheading">{{ subheading }}</p>
    </header>
  </section>
{% endmacro %}