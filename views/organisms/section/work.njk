---
template:
  id: "templates.organisms.section.work"
  name: "Work Section"
  type: "organism"
  status: "active"

source:
  path: "frontend/views/organisms/section/work.njk"
  engine: "nunjucks"

purpose:
  summary: "Homepage work/projects section — section header, industry jump links, and project cards grouped by industry."

data:
  expects:
    - "params.copy.heading"
    - "params.copy.subheading"
    - "params.copy.body"
    - "params.projects (array)"
    - "params.projectsByIndustry (array)"
    - "params.order"
    - "params.buildDate"

components:
  uses:
    - "molecules/section-cap.njk"
    - "molecules/card/project.njk"

contentModel:
  sanityTypes:
    - "project"
    - "industry"

tags:
  - "organism"
  - "section"
  - "work"
  - "projects"
  - "homepage"
  - "sanity"
---

{% macro render(params = {}) %}
  {% import "molecules/section-cap.njk" as SectionCap %}
  {% import "molecules/card/project.njk" as Card %}

  {%- set sectionId = params.id | default("work") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading | default("Work") -%}
  {%- set subheading = params.copy.subheading | default("") -%}
  {%- set body = params.copy.body | default("") -%}
  {%- set order = params.order | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}
  {%- set buildDate = params.buildDate -%}

  {%- set projects = params.projects | default([]) -%}
  {%- set projectsByIndustry = params.projectsByIndustry | default([]) -%}

  <section id="{{ sectionId }}" class="bg-striped relative z-10 col-span-full space-y-4 p-4 {{ classes }} " aria-labelledby="{{ headingId }}" data-scroll-section>
    <header
      data-projects-el="header"
      class="bg-white grid grid-cols-6 gap-2 outline outline-1 outline-black outline-offset-[-6px] p-4">
      <div
        data-projects-el="context"
        class="gap-1 pb-2 text-xs font-thin col-span-full flex items-center justify-between border-b border-black border-dashed">
        {{ SectionCap.render({title: sectionId , count: order, buildDate: buildDate}) }}
      </div>
      <h2 id="{{ headingId }}" data-projects-el="heading" class="col-span-2 font-display text-4xl sm:text-5xl mt-4 ">{{ heading }}</h2>
      {% if projectsByIndustry | length %}
        <nav aria-label="Jump to industries" class="col-span-4 border-l-2 border-black pl-4">
          <ul data-projects-el="industry-links" class="leading-none">
            {% for industry in projectsByIndustry %}
              {% if industry.projects | length %}
                <li class="my-0 leading-none">
                  <a
                    href="#industry-{{ industry.conceptId }}"
                    data-projects-el="industry-link"
                    class="block py-0 no-underline font-display text-sm leading-snug">{{ industry.title }}</a>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </nav>
      {% endif %}
    </header>
    {% if projectsByIndustry | length %}
      {% set industryHeadingIndex = 0 %}
      {% for industry in projectsByIndustry %}
        {% if industry.projects | length %}
          {% set industryHeadingIndex = industryHeadingIndex + 1 %}
          {% set industryLabelIndex = industryHeadingIndex %}
          {% if industryHeadingIndex < 10 %}
            {% set industryLabelIndex = "0" ~ industryHeadingIndex %}
          {% endif %}
          <section
            data-projects-el="industry-group"
            class="relative z-10 col-span-full"
            aria-labelledby="industry-{{ industry.conceptId }}">
            <h3
              id="industry-{{ industry.conceptId }}"
              data-projects-el="industry-heading"
              class="arrow-prefix bg-white outline outline-1 outline-black outline-offset-[-6px] p-4 font-display font-bold text-xl
                px-4 mb-4">{{ industryLabelIndex }}
              {{ industry.title }}</h3>
            <ul data-projects-el="list" class="col-span-full -mx-4">
              {% for project in industry.projects %}
                <li data-projects-el="project">
                  {{ Card.render({ project: project, headingLevel: 4, eager: loop.first and loop.parent.first }) }}
                </li>
              {% endfor %}
            </ul>
          </section>
        {% endif %}
      {% endfor %}
    {% else %}
      <p class="col-span-full">No projects found.</p>
    {% endif %}
  </section>
{% endmacro %}