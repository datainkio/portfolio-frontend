{% macro render(params = {}) %}
  {% import "molecules/section-cap.njk" as SectionCap %}
  {% import "molecules/card/project.njk" as Card %}
  {% import "molecules/list/projects-by-industry.njk" as ProjectsByIndustry %}

  {%- set sectionId = params.id | default("work") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading | default("Work") -%}
  {%- set subheading = params.copy.subheading | default("") -%}
  {%- set body = params.copy.body | default("") -%}
  {%- set order = params.order | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}
  {%- set buildDate = params.buildDate -%}
  {%- set industries = params.projects | groupBy("industry") | default([]) -%}

  <section id="{{ sectionId }}" class="relative col-span-full {{ classes }} " aria-labelledby="{{ headingId }}" data-scroll-section>
    <header
      data-projects-el="header"
      class="relative z-20 bg-white grid grid-cols-6 gap-2 outline outline-1 outline-black outline-offset-[-6px] p-4 pb-8
        sm:pb-4">
      <div
        data-projects-el="context"
        class="gap-1 pb-2 text-xs font-thin col-span-full flex items-center justify-between border-b border-black border-dashed">
        {{ SectionCap.render({title: sectionId , count: order, buildDate: buildDate}) }}
      </div>
      <h2 id="{{ headingId }}" data-projects-el="heading" class="col-span-full sm:col-span-2 font-display text-2xl sm:text-5xl sm:mt-4 ">{{ heading }}</h2>
      {% if industries | length %}
        <nav aria-label="Jump to an industry" data-projects-el="jumplinks" class="col-span-full sm:col-span-4 sm:border-l-2 border-black pl-4">
          {{ ProjectsByIndustry.render({ industries: industries }) }}
        </nav>
      {% endif %}
    </header>
    {% if industries | length %}
      {% set industryHeadingIndex = 0 %}
      {% for industryTitle, projects in industries %}
        {% if projects | length %}
          {% set industryHeadingIndex = industryHeadingIndex + 1 %}
          {% set industryLabelIndex = industryHeadingIndex %}
          {% if industryHeadingIndex < 10 %}
            {% set industryLabelIndex = "0" ~ industryHeadingIndex %}
          {% endif %}
          <section
            data-projects-el="industry-group"
            class="relative z-10 col-span-full"
            aria-labelledby="industry-{{ industryTitle | slugify }}">
            <h3
              id="industry-{{ industryTitle | slugify }}"
              data-projects-el="industry-heading"
              class="z-21 arrow-prefix bg-white outline outline-1 outline-black outline-offset-[-6px] p-4 font-display font-bold
                text-xl px-4 mb-4">{{ industryLabelIndex }}
              {{ industryTitle }}</h3>
            <ul data-projects-el="list" class="col-span-full">
              {% for project in projects %}
                <li data-projects-el="project" class="-z-1">
                  {{ Card.render({ project: project, headingLevel: 4, eager: loop.first and loop.parent.first }) }}
                </li>
              {% endfor %}
            </ul>
          </section>
        {% endif %}
      {% endfor %}
    {% else %}
      <p class="col-span-full">No projects found.</p>
    {% endif %}
  </section>
{% endmacro %}