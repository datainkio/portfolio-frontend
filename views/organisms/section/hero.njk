---
template:
  id: "templates.organisms.section.hero"
  name: "Hero Section"
  type: "organism"
  status: "active"

source:
  path: "frontend/views/organisms/section/hero.njk"
  engine: "nunjucks"

purpose:
  summary: "Homepage hero section — full-viewport height display typeface tagline with GSAP animation target attributes."

data:
  expects:
    - "params.id"
    - "params.tagline"
    - "params.ruler"
    - "params.classes"
    - "params.headingId"
    - "title (11ty page title fallback)"

a11y:
  headingContext:
    baseLevel: 1

design:
  interactions:
    - "GSAP data-hero-el targeting"

tags:
  - "organism"
  - "section"
  - "hero"
  - "homepage"
  - "gsap"
---

{% macro render(params = {}) %}
  {%- set sectionId = params.id | default("hero") -%}
  {%- set tagline = params.tagline | default(title) -%}
  {%- set rulerOptions = params.ruler | default({}) -%}
  {%- set classes = params.classes | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}

  {# Let's make styling the tagline text a little more manageable... #}
  {%- set font = "font-display text-primary-100 uppercase" -%}
  {%- set layout = "w-full h-1/2 flex flex-col justify-end overflow-hidden z-10 px-3 py-8" -%}
  {%- set sizes = "text-6xl sm:text-7xl md:text-8xl lg:text-9xl" -%}
  {%- set leading = "leading-12 sm:leading-14 md:leading-16 lg:leading-28" -%}
  {%- set tracking = "" -%}

  <section id="{{ sectionId }}" class="z-10 col-span-full h-dvh {{ classes }}" aria-labelledby="{{ headingId }}" data-scroll-section>
    <h1 id="{{ headingId }}" data-hero-el="tagline" class="{{ layout }} {{ sizes }} {{ leading }} {{ tracking }} {{ font }}">
      {{ tagline }}
    </h1>
  </section>
{% endmacro %}