---
template:
  id: "templates.organisms.section.awards"
  name: "Awards Section"
  type: "organism"
  status: "active"

source:
  path: "frontend/views/organisms/section/awards.njk"
  engine: "nunjucks"

purpose:
  summary: "Homepage recognition/awards section — section header with copy and a grid of award cards."

data:
  expects:
    - "params.id"
    - "params.copy.heading"
    - "params.copy.subheading"
    - "params.copy.body"
    - "params.order"
    - "params.awards (array of Sanity award objects)"

components:
  uses:
    - "molecules/section-cap.njk"
    - "molecules/card/award.njk"

contentModel:
  sanityTypes:
    - "recognitionItem"

tags:
  - "organism"
  - "section"
  - "awards"
  - "homepage"
  - "sanity"
---

{% macro render(params = {}) %}
  {% import "molecules/section-cap.njk" as SectionCap %}
  {% import "molecules/card/award.njk" as Card %}

  {%- set sectionId = params.id | default("recognition") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading -%}
  {%- set subheading = params.copy.subheading -%}
  {%- set body = params.copy.body -%}
  {%- set order = params.order | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}

  {%- set awards = params.awards | default([]) -%}

  <section id="{{ sectionId }}" class="relative col-span-full space-y-48 grid grid-cols-subgrid p-0 {{ classes }} " aria-labelledby="{{ headingId }}" data-scroll-section>
    <header data-awards-el="header" class="col-span-full z-10 p-4 pt-10 space-y-4">
      <div data-awards-el="context" class="text-sm col-span-full">
        {{ SectionCap.render({title: sectionId , count: order}) }}
      </div>
      <h2 id="{{ headingId }}" data-awards-el="heading" class="col-span-full font-display">{{ heading }}</h2>
      <p data-awards-el="body" class="col-span-full">{{ body }}</p>
    </header>
    {% if awards | length %}
      <ul data-awards-el="list" class="col-span-full grid grid-cols-subgrid gap-2 px-4 bg-black">
        {% for award in awards %}
          {%- set awardTitle = award.title | default("Untitled award") -%}
          {%- set awardImage = award.organization.logo | default(award.logo) -%}
          {%- set awardUrl = award.url | default("") -%}
          <li data-awards-el="award" class="text-neutral-500 col-span-2">
            {{ Card.render({ title: awardTitle, image: awardImage, url: awardUrl }) }}
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p class="col-span-full">No awards found.</p>
    {% endif %}
  </section>
{% endmacro %}