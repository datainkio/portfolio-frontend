{% macro render(params = {}) %}
  {% import "molecules/section-cap.njk" as SectionCap %}
  {% import "atoms/award.njk" as Award %}
  {% import "atoms/svg/inline.njk" as InlineSvg %}
  {% import "atoms/printmarks/ink-marks.njk" as Ink %}

  {%- set sectionId = params.id | default("recognition") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading -%}
  {%- set order = params.order | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}
  {%- set headerAwardInline = params.headerAwardInline | default('<svg xmlns="http://www.w3.org/2000/svg" class="fill-current" viewBox="0 0 220 220"><path d="M156.317 131.076c13.788-16.383 27.216-8.124 27.216-8.124-8.826 18.705-27.216 8.124-27.216 8.124"/><path d="M118.074 147.133a1.225 1.225 0 0 1-.483-2.354c36.102-15.372 57.14-34.931 62.538-58.136 3.581-15.403-.636-29.56-4.8-38.724-4.527-9.96-9.95-16.302-10.005-16.364a1.225 1.225 0 0 1 .131-1.729 1.226 1.226 0 0 1 1.731.129c.233.266 5.704 6.676 10.376 16.95 4.324 9.51 8.69 24.219 4.952 40.293-5.581 24.009-27.1 44.142-63.962 59.838a1.3 1.3 0 0 1-.478.097M151.381 0c18.619 7.381 11.94 28.133 11.94 28.133C142.186 13.655 151.381 0 151.381 0m24.6 6.062c16.814 20.995 2.798 34.324 2.798 34.324-13.819-18.781-2.798-34.324-2.798-34.324"/><path d="M147.926 31.75c15.693-1.748 20.612 14.862 20.612 14.862-14.414 3.393-20.612-14.862-20.612-14.862m46.067 5.236c6.631 22.757-7.495 25.452-7.495 25.452-8.915-20.188 7.495-25.452 7.495-25.452M156.49 52.44c21.7.591 21.5 22.805 21.5 22.805-13.911 2.524-21.5-22.805-21.5-22.805m11.227 25.458c11.076 14.114-.005 29.888-.005 29.888-14.507-8.346.005-29.888.005-29.888m-12.793 22.952c6.847 17.357-10 25.876-10 25.876-7.965-17.902 10-25.876 10-25.876m-36.386 40.29c-3.29-17.497 18.402-22.288 18.402-22.288 4.936 10.567-18.402 22.288-18.402 22.288m67.524-53.007c17.478-2.128 12.469-22.04 12.469-22.04-16.269 3.938-12.469 22.04-12.469 22.04m-9.486 25.677c2.614-21.548 21.01-19.443 21.01-19.443.728 14.059-21.01 19.443-21.01 19.443m-12.486 30.552c-18.866 10.719-27.009-3.622-27.009-3.622 11.009-8.735 27.009 3.622 27.009 3.622m-15.297 10.933c-11.391 11.757-29.614-4.395-29.614-4.395 4.914-9.631 29.614 4.395 29.614 4.395m-36.014-3.638s12.823 4.493 12.257 15.01c0 0-13.412-5.034-12.257-15.01m-96.312-28.705s13.428-8.259 27.216 8.124c0 0-18.39 10.581-27.216-8.124"/><path d="M81.926 147.133a1.225 1.225 0 0 0 .483-2.354c-36.104-15.372-57.142-34.931-62.538-58.136-3.58-15.403.636-29.56 4.8-38.724 4.527-9.96 9.95-16.302 10.005-16.364a1.226 1.226 0 0 0-.13-1.729 1.226 1.226 0 0 0-1.732.129c-.233.266-5.704 6.676-10.376 16.95-4.324 9.51-8.69 24.219-4.952 40.293 5.58 24.009 27.1 44.142 63.962 59.838.152.064.319.097.478.097m-45.247-119S29.998 7.38 48.619 0c0 0 9.195 13.655-11.94 28.133M21.221 40.386S7.205 27.057 24.02 6.062c0 0 11.022 15.543-2.798 34.324"/><path d="M31.462 46.612S36.38 30 52.074 31.75c0 0-6.198 18.255-20.612 14.862M13.505 62.44S-.624 59.744 6.01 36.989c0 0 16.407 5.262 7.495 25.453m8.505 12.806s-.2-22.215 21.5-22.805c0 0-7.589 25.326-21.5 22.805m10.278 32.538s-11.08-15.774-.005-29.888c0 0 14.512 21.543.005 29.888m22.788 18.943s-16.847-8.519-10-25.877c0 0 17.965 7.972 10 25.877m7.984-7.877s21.69 4.793 18.402 22.288c0 0-23.338-11.721-18.403-22.288M1.47 66.093s-5.01 19.912 12.468 22.04c0 0 3.8-18.102-12.469-22.04m.945 28.274s18.398-2.105 21.01 19.443c0 0-21.738-5.384-21.01-19.443M62.92 140.74s-8.144 14.339-27.01 3.622c0 0 16-12.357 27.01-3.622m17.9 10.16s-18.222 16.152-29.615 4.395c0 0 24.702-14.026 29.614-4.395m-5.857 15.767c-.564-10.517 12.257-15.01 12.257-15.01 1.157 9.976-12.257 15.01-12.257 15.01"/></svg>') -%}
  {%- set headerAwardMedia = params.headerAwardMedia | default(headerAwardInline) -%}
  {%- set headerAwardLooksSvg = '<svg' in headerAwardMedia -%}
  {%- set headerAwardLogo = '' if headerAwardLooksSvg else headerAwardMedia -%}

  {%- set awards = params.awards | default([]) -%}

  <section id="{{ sectionId }}" class="relative p-4 bg-white text-black col-span-full prose {{ classes }}" id="{{ sectionId }}" aria-labelledby="{{ headingId }}" data-scroll-section>

    <div
      aria-hidden="true"
      data-awards-el="context"
      class="text-xs font-light text-neutral-500 uppercase tracking-wide col-span-3 place-content-end border-b border-b-2
        border-dotted border-black py-4 mb-6">
      {{ Ink.render({classes: "inset-4"}) }}
      {{ SectionCap.render({title: sectionId , count: order}) }}
    </div>

    <header
      data-awards-el="header"
      class="z-10 border border-black border-2 divide-x-2 divide-black flex flex-row items-center gap-4">
      {{ InlineSvg.render({classes: "p-0 size-24 pt-4 pl-2", logoInline: headerAwardMedia, logo: headerAwardLogo, logoAlt: "Award badge" }) }}
      <h2 id="{{ headingId }}" data-awards-el="heading" class="font-display text-5xl">{{ heading }}</h2>
    </header>

    <div id="subheading" class="font-display tracking-wide flex flex-row px-4 border-b-2 border-x-2 border-black py-4">
      <p data-awards-el="subheading" class="font-bold w-5/12 leading-none h-full my-auto">Awards, Fellowship, and Distinctions</p>
      <p data-awards-el="subheading" class="text-neutral-500 text-sm w-7/12 leading-none my-auto">Selected honors received for
        work in design, technology & public impact</p>
    </div>

    <ul data-awards-el="list" class="sm:columns-2 gap-0 border-r-2 border-black">
      {% for orgId, group in awards | groupByOrg %}
        <li data-awards-el="group" class="break-inside-avoid py-2 border-l-2 border-b-2 border-black">
          <article data-awards-el="group-header" class="relative h-30 flex flex-row gap-4 px-4 py-2">
            {%- set logo = group.organization.logo.asset.url | default('/assets/images/logos/default.svg') -%}
            {%- set logoAlt = group.organization.logo.alt | default(group.organization.title) -%}
            {{ InlineSvg.render({classes: "size-20 w-1/4 my-auto", logoInline: group.organization.logo.inline, logo: logo, logoAlt: logoAlt }) }}
            <div class="w-3/4 h-full p-4 flex flex-col justify-center border-l border-l-2 border-dotted border-black">
              <h3 class="font-display font-bold text-base leading-none pt-2">{{ group.organization.title }}</h3>
              <ul class="m-0 mt-0 p-0" data-awards-el="group-list">
                {% for award in group.items %}
                  <li class="text-xs font-light m-0" data-awards-el="award">
                    {{ Award.render(award) }}
                  </li>
                {% endfor %}
              </ul>
            </div>
          </article>
        </li>
      {% endfor %}
    </ul>
  </section>
{% endmacro %}