---
template:
  id: "templates.organisms.section.organizations"
  name: "Organizations Section"
  type: "organism"
  status: "active"

source:
  path: "frontend/views/organisms/section/organizations.njk"
  engine: "nunjucks"

purpose:
  summary: "Homepage organizations section — section header and a grid of organization logos sourced from Sanity."

data:
  expects:
    - "params.copy.heading"
    - "params.copy.body"
    - "params.order"
    - "params.organizations (array of Sanity organization objects)"

components:
  uses:
    - "molecules/section-cap.njk"
    - "atoms/organization.njk"

contentModel:
  sanityTypes:
    - "organization"

tags:
  - "organism"
  - "section"
  - "organizations"
  - "homepage"
  - "sanity"
---

{% macro render(params = {}) %}
  {% import "molecules/section-cap.njk" as SectionCap %}
  {% import "atoms/organization.njk" as Organization %}

  {%- set sectionId = params.id | default("organizations") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set heading = params.copy.heading -%}
  {%- set subheading = params.copy.subheading -%}
  {%- set body = params.copy.body -%}
  {%- set order = params.order | default("") -%}
  {%- set headingId = params.headingId | default(sectionId ~ "-heading") -%}

  {%- set organizations = params.organizations | default([]) -%}

  <section id="{{ sectionId }}" class=" bg-white relative z-10 col-span-full grid grid-cols-subgrid p-0 {{ classes }} " aria-labelledby="{{ headingId }}" data-scroll-section>
    <header data-organizations-el="header" class="col-span-full">
      <div data-organizations-el="context" class="text-sm col-span-full">
        {{ SectionCap.render({title: sectionId , count: order}) }}
      </div>
      <h2 id="{{ headingId }}" data-organizations-el="heading" class="col-span-full">{{ heading }}</h2>
      <p data-organizations-el="body" class="col-span-full">{{ body }}</p>
    </header>
    {% if organizations | length %}
      <ul data-organizations-el="list" class="col-span-full grid grid-cols-2 gap-4">
        {% for organization in organizations %}
          <li data-organizations-el="organization">
            {{ Organization.render(organization) }}
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p class="col-span-full">No organizations found.</p>
    {% endif %}
  </section>
{% endmacro %}