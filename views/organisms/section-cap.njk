---
template:
  id: "templates.organisms.section-cap"
  name: "Section Cap"
  type: "organism"
  status: "active"

source:
  path: "frontend/views/organisms/section-cap.njk"
  engine: "nunjucks"

purpose:
  summary: "Fixed position ruler element pinned to the top of the viewport, providing a persistent visual anchor across scroll sections."

components:
  uses:
    - "atoms/ruler.njk"

tags:
  - "organism"
  - "section"
  - "ruler"
---

{% import "atoms/ruler.njk" as Ruler %}
{% macro render(params = {}) %}
  {%- set id = params.id | default("section-cap-anchor") -%}
  <div id="{{ id }}" class="fixed top-8 left-0 w-full px-4 pointer-events-none z-30">
    {{ Ruler.render({classes: "h-8 m-0"}) }}
  </div>
{% endmacro %}