{% macro render(params = {}) %}
  {% set crumbs = collections.all | eleventyNavigationBreadcrumb(eleventyNavigation.key) %}
  <nav aria-label="Breadcrumb">
    <ol>
      {% for crumb in crumbs %}
        <li>
          <a href="{{ crumb.url | url }}">{{ crumb.title }}</a>
        </li>
      {% endfor %}
    </ol>
  </nav>
{% endmacro %}