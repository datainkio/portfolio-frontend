---
template:
  id: "templates.organisms.navigation.skip-links-nav"
  name: "Skip Links Navigation"
  type: "organism"
  status: "active"

source:
  path: "frontend/views/organisms/navigation/skip-links-nav.njk"
  engine: "nunjucks"

purpose:
  summary: "Accessible skip links rendered as a screen-reader-visible nav for keyboard users to jump to page landmarks."

data:
  expects:
    - "params.items (array of landmark IDs)"
    - "skipLinks (global data fallback)"

a11y:
  landmarks:
    - "nav[aria-label='Skip links']"
  notes: "sr-only by default; keyboard-focusable for accessibility."

tags:
  - "organism"
  - "navigation"
  - "a11y"
  - "skip-links"
---

{% macro render(params = {}) %}
   -%}

  {%- if items and items | length -%}
    <a href="#page-main" class="sr-only" aria-label="Skip to main content">Skip to main content</a>
    <nav class="skip-links sr-only " aria-label="Skip links">
      <ul role="list">
        {%- for id in items -%}
          <li>
            <a href="#{{ id }}">
              {{ id | replace("-", " ") | capitalize }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>
  {%- endif -%}
{% endmacro %}