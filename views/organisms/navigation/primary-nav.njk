---
template:
  id: "templates.organisms.navigation.primary-nav"
  name: "Primary Navigation"
  type: "organism"
  status: "active"

source:
  path: "frontend/views/organisms/navigation/primary-nav.njk"
  engine: "nunjucks"

purpose:
  summary: "Primary site navigation bar with site title and main page links; sources items from CMS navigation or eleventyNavigation fallback."

data:
  expects:
    - "params.siteName"
    - "cms.navigation[0].headerItems"
    - "collections.nav_primary"
    - "collections.all"

components:
  uses:
    - "atoms/link/site-title.njk"
    - "molecules/list/main-pages.njk"

contentModel:
  sanityTypes:
    - "navigation"

tags:
  - "organism"
  - "navigation"
  - "primary"
  - "sanity"
---

{% import "atoms/link/site-title.njk" as site_title with context %}
{% import "molecules/list/main-pages.njk" as main_pages with context %}

{% macro render(params = {}) %}
  {% set navClasses = params.class or params.navClasses or "flex items-center justify-between" %}
  {% set siteName = params.siteName or site.siteName or "data:ink:io" %}
  {% set cmsNavigation = (cms and cms.navigation and cms.navigation[0]) or {} %}
  {% set cmsItems = params.items or cmsNavigation.headerItems or [] %}
  {% set navPrimary = collections.nav_primary or [] %}
  {% set fallbackItems = navPrimary if (navPrimary and navPrimary.length) else (collections.all | eleventyNavigation) %}
  {% set items = cmsItems if (cmsItems and cmsItems.length) else fallbackItems %}
  {% set siteTitleId = params.siteTitleId or "primary-site-title" %}

  <nav id="primary-nav" class="{{ navClasses }}" aria-label="Primary navigation">
    {{ site_title.render({
        siteName: siteName,
        href: "/",
        classes: "mr-auto whitespace-nowrap",
        id: siteTitleId
      }) }}
    {{ main_pages.render({
      classes: "flex list-none items-center gap-6 m-0",
      items: items,
      linkClass: ""
    }) }}
  </nav>
{% endmacro %}