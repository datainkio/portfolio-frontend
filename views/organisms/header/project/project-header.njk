{% import "organisms/navigation/breadcrumbs-nav.njk" as BreadCrumbs with context %}
{% import "organisms/project-metadata/project-metadata.njk" as ProjectMetadata %}
{% import "molecules/list/project-orgs.njk" as ProjectOrgs %}
{% import "molecules/figure/featured-image.njk" as FeaturedImage %}

{% macro render(params) %}

  {%- set header = {
    "base": "relative col-span-full h-dvh inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent overflow-hidden text-neutral-100",
    "sm": "",
    "md": "",
    "lg": "",
    "xl": ""
  } -%}

  {%- set heading = {
    "base": "relative text-12 font-display leading-12",
    "sm": "leading-18",
    "md": "w-full leading-20",
    "lg": "",
    "xl": ""
  } -%}

  {%- set gradient = {
    "base": "absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent z-[1]",
    "sm": "",
    "md": "",
    "lg": "",
    "xl": ""
  } -%}

  <header
    data-project-header class="{{ header | classes }}">
    {# Image layer: 130% tall so yPercent parallax travel never exhausts the image #}
    {{ FeaturedImage.render({ image: params.project.featuredImage, alt: params.project.title, class: "absolute inset-x-0 top-0 h-[130%] w-full", attrs: "data-project-header-image" }) }}
    {# Content overlay: anchored to the bottom of the hero #}
    <div class="{{ gradient | classes }} z-[2] flex flex-col justify-end h-full px-12 sm:px-16 lg:px-24 pb-12 sm:pb-14 lg:pb-16 gap-y-4">
      {{ BreadCrumbs.render({ key: breadcrumbKey or (eleventyNavigation and eleventyNavigation.key), nav: collections.all, classes: 'w-full' }) }}
      <h1 data-landing-header-title class="{{ heading | classes }}">
        {{ params.project.title | default('Untitled') }}
      </h1>
      {{ ProjectOrgs.render({ orgs: params.project.organization, class: byline | classes }) }}
      {{ ProjectMetadata.render({ project: params.project, classes: metadata | classes, aria: "Project metadata" }) }}
    </div>
  </header>
{% endmacro %}