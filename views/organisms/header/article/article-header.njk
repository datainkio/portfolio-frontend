{% import "atoms/hanko.njk" as Hanko %}
{% import "organisms/navigation/breadcrumbs-nav.njk" as breadcrumbs with context %}

{% macro render(params) %}
  {%- set hanko = {
    "base": "nav-link block col-span-3 size-12 justify-self-end",
    "sm": "size-16 pt-1",
    "md": "",
    "lg": "col-span-3 size-36",
    "xl": ""
  } -%}
  {%- set heading = {
    "base": "col-span-4 font-display text-6xl leading-12",
    "sm": "text-8xl leading-18",
    "md": "text-10xl leading-20",
    "lg": "",
    "xl": ""
  } -%}
  {%- set abstract = {
    "base": "col-span-8 col-start-4 max-w-none pl-2",
    "sm": "",
    "md": "",
    "lg": "col-span-5 col-start-7 row-start-2 pl-0",
    "xl": ""
  } -%}
  {{ breadcrumbs.render({ key: breadcrumbKey or (eleventyNavigation and eleventyNavigation.key), nav: collections.all, classes: 'col-span-full w-full' }) }}
  <a href="/" class="{{ hanko | classes }}" aria-label="Home">
    {{ Hanko.render({ svg: params.logoSvg, classes: "text-secondary-700" }) }}
  </a>
  <h1 data-landing-header-title class="{{ heading | classes }}">
    {{ params.title | default('Untitled') }}
  </h1>
  {% if params.abstract and params.abstract | length > 0 %}
    <section data-doc-abstract class="{{ abstract | classes }}">
      {{ params.abstract | safe }}
    </section>
  {% endif %}
{% endmacro %}