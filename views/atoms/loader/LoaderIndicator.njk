---
template:
  id: "templates.atoms.loader.loader-indicator"
  name: "Loader Indicator"
  type: "atom"
  status: "active"

source:
  path: "frontend/views/atoms/loader/LoaderIndicator.njk"
  engine: "nunjucks"

purpose:
  summary: "Animated loading indicator — renders either a spinner ring or a shimmer progress bar."

data:
  expects:
    - "kind ('spinner' | 'bar', default: 'spinner')"

tags:
  - "atom"
  - "loader"
  - "animation"
---

{% macro render(kind = "spinner") -%}
  {# kind can be "spinner" or "bar" #}
  {% if kind == "bar" %}
    <span class="mt-3 block h-1 w-24 overflow-hidden rounded-full bg-white/15">
      <span class="block h-full w-1/3 rounded-full bg-white/80 animate-[loader-shimmer_1.2s_ease-in-out_infinite]"></span>
    </span>
  {% else %}
    <span class="mt-3 inline-block h-8 w-8 animate-[loader-spin_1.1s_linear_infinite] rounded-full border-2 border-white/25
      border-t-white/90"></span>
  {% endif %}
{%- endmacro %}