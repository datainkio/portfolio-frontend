---
template:
  id: "templates.atoms.loader.loader-mark"
  name: "Loader Mark"
  type: "atom"
  status: "active"

source:
  path: "frontend/views/atoms/loader/LoaderMark.njk"
  engine: "nunjucks"

purpose:
  summary: "Brand wordmark displayed during the site loading sequence."

data:
  expects:
    - "text (string, default: 'dataink.io')"

tags:
  - "atom"
  - "loader"
  - "brand"
---

{% macro render(text = "dataink.io") -%}
  <span class="text-sm font-semibold tracking-[0.18em] uppercase text-white/90">{{ text }}</span>
{%- endmacro %}