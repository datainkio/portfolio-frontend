---
template:
  id: "templates.atoms.link.site-title"
  name: "Site Title"
  type: "atom"
  status: "active"

source:
  path: "frontend/views/atoms/link/site-title.njk"
  engine: "nunjucks"

purpose:
  summary: "Site name rendered as a linked button, used in the primary navigation header."

data:
  expects:
    - "params.siteName (default: site.siteName)"
    - "params.href (default: '/')"
    - "params.classes"

tags:
  - "atom"
  - "link"
  - "site-title"
  - "navigation"
---

{# 
  Site Title Atom
  Displays the site name as a linked button, typically used in navigation headers but adaptable to other contexts if you're willing to get a little creative with CSS.
  @param {string} params.siteName - Site name to display (defaults to site.siteName)
  @param {string} params.href - Link destination (defaults to "/")
  @param {string} params.classes - Additional CSS classes
#}
{% macro render(params = {}) %}
  {%- set siteName = params.siteName or site.siteName or 'data:ink:io' -%}
  {%- set href = params.href | default('/') -%}
  {%- set classes = params.classes | default('text-xl') -%}
  {%- set id = params.id | default('site-title') -%}
  <a id="{{ id }}" class="{{ classes }}" href="{{ href }}">
    {{ siteName }}
  </a>
{% endmacro %}