{#
Base Link Atom Component
Provides consistent link styling across the site
Supports external links, download links, and accessibility features
#}

{% set linkUrl = url %}
{% set linkText = text or title %}
{% set isExternal = linkUrl and (linkUrl.startsWith('http') or linkUrl.startsWith('mailto:') or linkUrl.startsWith('tel:')) %}
{% set isDownload = download %}

<a href="{{ linkUrl }}" class="base-link text-primary-600 hover:text-primary-800 underline transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-1 {{ class }}" {% if isExternal %} target="_blank" rel="noopener noreferrer" {% endif %} {% if isDownload %} download {% endif %} {% if ariaLabel %} aria-label="{{ ariaLabel }}" {% endif %} {% if title %} title="{{ title }}" {% endif %}>
  {{ linkText }}

  {# External link indicator #}
  {% include "atoms/icon/external-link.njk" with { isExternal: isExternal } %}
</a>