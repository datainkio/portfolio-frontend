---
template:
  id: "templates.atoms.field"
  name: "Debug Field"
  type: "atom"
  status: "active"

source:
  path: "frontend/views/atoms/field.njk"
  engine: "nunjucks"

purpose:
  summary: "Development utility — displays a data field name alongside its type and truncated value for schema inspection."

data:
  expects:
    - "field (field name)"
    - "value"

tags:
  - "atom"
  - "debug"
  - "dev"
---

<strong>{{ field }}</strong>
<span class="italic text-xs">{{ value | datatype }}</span>
<span class="block italic text-sm break-words">
  {% if value | datatype == "string" %}
    {{ value | truncate(128) }}
  {% elif value | datatype == "array" %}
    {% if value[0] | datatype == "object" %}
      <ul>
        {% for item in value %}
          {% for key, val in item %}
            <li>
              <strong>{{ key }}</strong>: {{ val }}</li>
          {% endfor %}
        {% endfor %}
      </ul>
    {% else %}
      [{{ value | join | truncate(128) }}]
    {% endif %}
  {% else %}
    {{ value }}
  {% endif %}
</span>