---
template:
  id: "templates.atoms.input"
  name: "Input"
  type: "atom"
  status: "active"

source:
  path: "frontend/views/atoms/input.njk"
  engine: "nunjucks"

purpose:
  summary: "Basic text input field atom with DaisyUI input classes."

data:
  expects:
    - "type"
    - "placeholder"

tags:
  - "atom"
  - "input"
  - "form"
---

<input type="{{ type | default('text') }}" placeholder="{{ placeholder | default('Enter text') }}" class="input input-bordered"/>