---
template:
  id: "templates.atoms.icon"
  name: "Icon"
  type: "atom"
  status: "active"

source:
  path: "frontend/views/atoms/icon.njk"
  engine: "nunjucks"

purpose:
  summary: "Unified SVG icon system — single component for all site icons; do not create separate .njk files for individual icons."

data:
  expects:
    - "name (icon key)"
    - "size ('sm' | 'md' | 'lg')"
    - "className"

agent:
  doNotEdit:
    - "icons object keys"
  reviewTriggers:
    - "new icon additions"
    - "Figma design token changes"

tags:
  - "atom"
  - "icon"
  - "svg"
  - "design-system"
---

{% set icons = {
  "direction-left": '<path d="M15.41 16.59L10.83 12L15.41 7.41L14 6l-6 6 6 6 1.41-1.41z" />',
  "direction-right": '<path d="M8.59 16.59L13.17 12L8.59 7.41L10 6l6 6-6 6-1.41-1.41z" />',
  "chevron-left": '<path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" />',
  "chevron-right": '<path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" />',
  "chevron-up": '<path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z" />',
  "chevron-down": '<path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z" />',
  "external-link": '<path d="M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z" />',
  "close": '<path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" />',
  "menu": '<path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" />'
} %}
{% set sizes = {
  "xs": "w-3 h-3",
  "sm": "w-4 h-4",
  "md": "w-5 h-5",
  "lg": "w-6 h-6",
  "xl": "w-8 h-8",
  "2xl": "w-10 h-10"
} %}
{% macro render(params = {}) %}
  {% set iconName = params.name | default("direction-left") %}
  {% set iconSize = params.size | default("md") %}
  {% set iconClasses = params.className | default(params.class | default("")) %}
  {% set sizeClasses = sizes[iconSize] | default(sizes.md) %}
  {% if icons[iconName] %}
    <svg class="{{ sizeClasses }} {{ iconClasses }}" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
      {{ icons[iconName] | safe }}
    </svg>
  {% else %}
    <!-- CRITICAL ERROR: Icon "{{ iconName }}" not found in icon registry -->
    <!-- Available icons: direction-left, direction-right, chevron-up, chevron-down, chevron-left, chevron-right,
    external-link, close, menu -->
      <span class="inline-block {{ sizeClasses }} bg-red-500 text-white text-xs flex items-center justify-center"> ?
    </span>
  {% endif %}
{% endmacro %}
{# Backward compatibility: render immediately when included directly #}
{% if renderImmediately | default(true) %}
  {{ render({
    name: name,
    size: size,
    className: className,
    class: class
  }) }}
{% endif %}