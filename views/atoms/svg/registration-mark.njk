{% macro render(params = {}) %}
  {% set classes = params.classes | default("") %}
  {% set invert = params.invert | default(false) %}
  {% set innerColor = "black" if invert else "white" %}
  {% set outerColor = "white" if invert else "black" %}
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 50 50" class="registration-mark {{ classes }}">
    <g class="outer">
      <circle class="stroke-{{ innerColor }}" cx="25" cy="25" r="20"/>
      <path class="horiz stroke-{{ innerColor }}" stroke-miterlimit="10" d="M0 25h50"/>
      <path class="vert stroke-{{ innerColor }}" stroke-miterlimit="10" d="M25 0v50"/>
    </g>
    <g class="inner">
      <circle class="fill-{{ innerColor }}" cx="25" cy="25" r="12"/>
      <path class="stroke-{{ outerColor }} stroke-3" stroke-miterlimit="10" d="M13 25h24"/>
      <path class="stroke-{{ outerColor }} stroke-3" stroke-miterlimit="10" d="M25 13v24"/>
    </g>

  </svg>
{% endmacro %}