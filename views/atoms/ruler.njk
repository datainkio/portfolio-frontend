---
template:
  id: "templates.atoms.ruler"
  name: "Ruler"
  type: "atom"
  status: "active"

source:
  path: "frontend/views/atoms/ruler.njk"
  engine: "nunjucks"

purpose:
  summary: "Decorative print-inspired ruler element — renders tick marks via JS into a container div."

data:
  expects:
    - "params.id"
    - "params.classes"
    - "params.intervals"
    - "params.subticksPerInterval"

tags:
  - "atom"
  - "ruler"
  - "print"
---

{% macro render(params = {}) %}
  {%- set classes = params.classes | default("") -%}
  {%- set className = ("ruler " ~ classes) | trim -%}
  {%- set intervals = params.intervals | default(12) -%}
  {%- set subticksPerInterval = params.subticksPerInterval | default(16) -%}
  <div id="{{ id }}" class="{{ className }}" role="presentation"></div>
  <script type="module">
    import {createRuler} from "/assets/js/displays/Ruler.js";
    const el = document.getElementById("{{ id }}");
    if (el) {
      const ruler = createRuler(el, {
        intervals: {{ intervals }},
        subticksPerInterval: {{ subticksPerInterval }}
      });
      // ruler.setOptions({ intervals: 24 }); ruler.destroy();
    }
  </script>
{% endmacro %}