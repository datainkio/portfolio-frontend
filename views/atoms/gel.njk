{#
  Gel Overlay Atom - SVG-masked background element with corner manipulation

  ARCHITECTURE:
  - gel.njk: Renders DOM element with ID and color class
  - Gel.js: Controls SVG polygon mask and corner animation
  - GelAnimationManager: Initializes and coordinates multiple gels on scroll
  - GelManipulator: Positions gel relative to viewport or reference element

  ELEMENT IDS AND CONFIGURATION:
  - Element ID must match arrangement keys used by gel choreography (e.g., id="bg-gel-0")
  - IDs use kebab-case format: bg-gel-0, bg-gel-1, bg-gel-2
  - .bg-gel class triggers automatic discovery during initialization
  - Color classes (bg-gel-primary, etc.) are optional styling

  USAGE:
  {% import "atoms/gel/gel.njk" as gelAtom %}
  {{ gelAtom.render({ color: 'bg-gel-primary', id: 'bg-gel-0' }) }}

  PARAMETERS:
  - color: CSS class for color state (default: 'bg-gel-primary')
  - id: Element ID matching gel arrangement entries (required for choreography)
#}
{% macro render(params = {}) %}
  {%- set color = params.color | default('bg-gel-primary') -%}
  {%- set id = params.id | default('gel-default') -%}

  <div id="{{ id }}" class="bg-gel absolute inset-0 {{ color }}" aria-hidden="true"></div>

{% endmacro %}