---
template:
  id: "templates.molecules.list.project-details"
  name: "Project Details"
  type: "partial"
  status: "active"

source:
  path: "frontend/views/molecules/list/project-details.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders a project's client organizations and roles as a compact definition list."
  role: "Inline project metadata strip; composes organizations and roles list partials."

data:
  expects:
    - "project (current project object — passed through to included partials)"
    - "collections.organizations"
  provides:
    - "dl with organizations and roles as dd elements"

components:
  uses:
    - "molecules/list/organizations.njk"
    - "molecules/list/roles.njk"

contentModel:
  sanityTypes:
    - "project"

a11y:
  headingContext:
    notes: "Uses dl/dt/dd semantics; dt values are sr-only."

dependencies:
  styles:
    - "tailwind"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
  reviewTriggers:
    - "organizations.njk or roles.njk changes"
    - "project data shape changes"

tags:
  - "molecule"
  - "list"
  - "project"
  - "metadata"
  - "nunjucks"
  - "partial"
---

<!-- PROJECT DETAILS -->
<dl class="flex flex-row flex-wrap gap-2 font-light content-center">
  <dt class="sr-only">Clients, Partners, and Employers</dt>
  <dd class=" border-r-neutral border-r pr-2 leading-tight">
    {% include "molecules/list/organizations.njk" %}
  </dd>
  <dt class="sr-only">Roles</dt>
  <dd class="leading-tight">{% include "molecules/list/roles.njk" %}</dd>
</dl>