---
template:
  id: "templates.molecules.list.roles"
  name: "Roles List"
  type: "partial"
  status: "active"

source:
  path: "frontend/views/molecules/list/roles.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders an inline comma-separated list of a project's roles."
  role: "Included in project detail contexts; requires project to be in scope."

data:
  expects:
    - "project.roles (array of role objects with title)"
  provides:
    - "inline ul of role titles"

contentModel:
  sanityTypes:
    - "project"

dependencies:
  styles:
    - "tailwind"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
  reviewTriggers:
    - "project roles schema changes"

tags:
  - "molecule"
  - "list"
  - "roles"
  - "project"
  - "nunjucks"
  - "partial"
---

{% set roles = project.roles %}
{% if roles %}
  <ul class="flex flex-row list-none p-0 m-0">
    {% for role in roles %}
      <li class="p-0 m-0">
        {{ role.title }}
        {% if not loop.last %},&nbsp;{% endif %}
      </li>
    {% endfor %}
  </ul>
{% endif %}