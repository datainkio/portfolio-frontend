---
template:
  id: "templates.molecules.list.industry"
  name: "Industry"
  type: "partial"
  status: "active"

source:
  path: "frontend/views/molecules/list/industry.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders an industry name heading and a list of associated organizations."
  role: "Included in industry-grouped project contexts; requires industry and orgs to be in scope."

data:
  expects:
    - "industry (string — industry name)"
    - "orgs (array of organization objects with name)"
  provides:
    - "h3 industry title with ul of org names"

a11y:
  headingContext:
    baseLevel: 3
    notes: "Industry name renders as h3; callers must ensure correct document outline."

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
  reviewTriggers:
    - "industry data shape changes"

tags:
  - "molecule"
  - "list"
  - "industry"
  - "nunjucks"
  - "partial"
---

<h3 class="text-lg font-extrabold leading-tight">{{ industry }}</h3>
<ul>
  {% for org in orgs %}
    <li>{{ org.name }}</li>
  {% endfor %}
</ul>