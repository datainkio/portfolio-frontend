---
template:
  id: "templates.molecules.list.child-pages"
  name: "Child Pages List"
  type: "partial"
  status: "active"

source:
  path: "frontend/views/molecules/list/child-pages.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders an unordered list of child page links for a given navigation entry."
  role: "Included within nav loop contexts to render nested page children via nav-link atoms."

data:
  expects:
    - "entry.children (array of nav child objects)"
  provides:
    - "ul of nav-link atoms for each child"

components:
  uses:
    - "atoms/link/nav-link.njk"

a11y:
  headingContext:
    notes: "No heading; renders as a plain list within its parent navigation context."

dependencies:
  styles:
    - "tailwind"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
  reviewTriggers:
    - "nav-link atom changes"
    - "nav data structure changes"

tags:
  - "molecule"
  - "list"
  - "navigation"
  - "nunjucks"
  - "partial"
---

<ul class="" role="list">
  {% for child in entry.children %}
    <li>{% set entry = child %}
      {% include "atoms/link/nav-link.njk" %}</li>
  {% endfor %}
</ul>