{% from "molecules/card/card.njk" import render as renderCard %}

{% macro render(params = {}) %}
  {%- set project = params.project or {} -%}
  {%- set card = params.card or (project and project.card) or {} -%}
  {%- set title = params.title | default(card.title) | default("Untitled project") -%}
  {%- set image = params.image | default(card.image) -%}
  {%- set url = params.url | default(card.url) | default("") -%}
  {%- set description = params.description | default(card.description) | default("") -%}
  {%- set eyebrow = params.eyebrow | default(card.eyebrow) | default("") -%}
  {%- set byline = params.byline | default(params.organization) | default(card.byline) | default("") -%}
  {%- set featured = params.featured | default(card.featured) | default(false) -%}
  {{ renderCard({
    title: title,
    image: image,
    url: url,
    eyebrow: eyebrow,
    description: description,
    byline: byline,
    featured: featured,
    classes: params.classes,
    imageClasses: params.imageClasses,
    showTitle: params.showTitle,
    eager: params.eager
  }) }}
{% endmacro %}