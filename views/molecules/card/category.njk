---
template:
  id: "templates.molecules.card.category"
  name: "Category Card"
  type: "molecule"
  status: "active"

source:
  path: "frontend/views/molecules/card/category.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders a project category card with associated projects and recognition items."
  role: "Groups portfolio work by IA category; surfaces project titles, awards, and outcomes for a given category."

data:
  expects:
    - "params.category (object with slug, title, projects array from collections.ia)"
    - "params.collections (Eleventy collections — requires collections.projects and collections.awards)"
    - "params.maxProjects (default 3)"
    - "params.showRecognition (default true)"
    - "params.showOutcomes (default true)"
  provides:
    - "category article with project list, awards, and outcomes sections"

contentModel:
  sanityTypes:
    - "project"
    - "award"

a11y:
  landmarks:
    - "article"
  headingContext:
    baseLevel: 3
    notes: "Category title renders as h3; project titles render as h4."

design:
  system:
    - "portfolio"

dependencies:
  styles:
    - "tailwind"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
  reviewTriggers:
    - "Sanity project or award schema changes"
    - "collections.ia shape changes"
    - "findRecord filter changes"
    - "heading-level changes"

tags:
  - "molecule"
  - "card"
  - "category"
  - "nunjucks"
  - "sanity"
---

{% macro render(params = {}) %}
  {%- set category = params.category -%}
  {%- set collections = params.collections -%}
  {%- set maxProjects = params.maxProjects | default(3) -%}
  {%- set showRecognition = params.showRecognition | default(true) -%}
  {%- set showOutcomes = params.showOutcomes | default(true) -%}

  <article id="{{ category.slug }}" class="category-card relative flex flex-col p-8 py-16 gap-8">
    <h3 class="text-6xl font-display font-black tracking-tight leading-none" data-text="{{ category.title }}">
      {{ category.title }}
    </h3>

    {# Lookup projects from collections - handle null/missing projects array #}
    {%- set categoryProjects = [] -%}
    {%- if category.projects and category.projects.length > 0 -%}
      {%- set categoryProjects = collections.projects | findRecord(category.projects) -%}
    {%- endif -%}

    <ul class="projects col-span-full space-y-12 mx-4">
      {% for project in categoryProjects | sortByKey("weight") | getByIndexRange(0, maxProjects - 1) %}
        <li class="break-inside-avoid">
          <h4 class="text-2xl font-bold">{{ project.title }}</h4>
        </li>
      {% endfor %}
    </ul>

    {# Collect all unique awards from projects in this category #}
    {%- set categoryAwardIds = [] -%}
    {%- for project in categoryProjects -%}
      {%- if project.awards and project.awards.length > 0 -%}
        {%- for awardId in project.awards -%}
          {%- if awardId and categoryAwardIds.indexOf(awardId) === -1 -%}
            {%- set categoryAwardIds = (categoryAwardIds.push(awardId), categoryAwardIds) -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}

    {# Lookup award records from collected IDs #}
    {%- set categoryAwards = [] -%}
    {%- if categoryAwardIds.length > 0 -%}
      {%- set categoryAwards = collections.awards | findRecord(categoryAwardIds) -%}
    {%- endif -%}

    {% if showRecognition and categoryAwards.length > 0 %}
      <h4>Recognition</h4>
      <ul class="awards-list list-disc list-inside">
        {% for award in categoryAwards %}
          <li>{{ award.organization }} / {{ award.title }}</li>
        {% endfor %}
      </ul>
    {% endif %}

    {% if showOutcomes %}
      <h4>Outcomes</h4>
    {% endif %}
  </article>
{% endmacro %}