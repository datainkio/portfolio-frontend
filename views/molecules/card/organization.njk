---
template:
  id: "templates.molecules.card.organization"
  name: "Organization Card"
  type: "molecule"
  status: "active"

source:
  path: "frontend/views/molecules/card/organization.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders an organization card by mapping a Sanity organization object to the base card macro."
  role: "Card variant for displaying client or partner organizations."

data:
  expects:
    - "params.organization (Sanity organization object with card sub-object)"
    - "params.card"
    - "params.title"
    - "params.image"
    - "params.url"
    - "params.eyebrow"
    - "params.description"
    - "params.meta"
    - "params.featured"
    - "params.classes"
    - "params.imageClasses"
    - "params.showTitle"
  provides:
    - "organization card with title, image, and optional CTA"

components:
  uses:
    - "molecules/card/card.njk"

contentModel:
  sanityTypes:
    - "organization"

a11y:
  headingContext:
    notes: "Heading level delegated to card.njk; default is 3."

dependencies:
  styles:
    - "tailwind"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
  reviewTriggers:
    - "Sanity organization schema changes"
    - "card.njk param signature changes"

tags:
  - "molecule"
  - "card"
  - "organization"
  - "nunjucks"
  - "sanity"
---

{% import "molecules/card/card.njk" as Card %}

{% macro render(params = {}) %}
  {%- set card = (params.organization and params.organization.card) or params.card or {} -%}
  {%- set title = params.title | default(card.title) | default("Untitled organization") -%}
  {%- set image = params.image | default(card.image) -%}
  {%- set url = params.url | default(card.url) | default("") -%}
  {%- set eyebrow = params.eyebrow | default(card.eyebrow) | default("") -%}
  {%- set description = params.description | default(card.description) | default("") -%}
  {%- set meta = params.meta | default(card.meta) | default("") -%}
  {%- set featured = params.featured | default(card.featured) | default(false) -%}

  {{ Card.render({
    title: title,
    image: image,
    url: url,
    eyebrow: eyebrow,
    description: description,
    meta: meta,
    featured: featured,
    classes: params.classes,
    imageClasses: params.imageClasses,
    showTitle: params.showTitle
  }) }}
{% endmacro %}