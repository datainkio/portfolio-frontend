---
template:
  id: "templates.molecules.card"
  name: "Card"
  type: "molecule"
  status: "active"

source:
  path: "frontend/views/molecules/card/card.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders a generic content card with optional image, title, eyebrow, byline, description, meta stats, and CTA."
  role: "Base card macro composed by all card variant molecules in this directory."

data:
  expects:
    - "params.title"
    - "params.image"
    - "params.url"
    - "params.description"
    - "params.eyebrow"
    - "params.byline"
    - "params.meta"
    - "params.headingLevel"
    - "params.featured"
    - "params.classes"
    - "params.imageClasses"
    - "params.eager"
  provides:
    - "article card with image, header, body, and footer regions"

components:
  uses:
    - "atoms/heading.njk"
    - "atoms/cta.njk"
    - "molecules/stats/stats.njk"
    - "atoms/printmarks/trim-marks.njk"

a11y:
  landmarks:
    - "article"
  headingContext:
    baseLevel: null
    notes: "Heading level is caller-controlled via params.headingLevel (default 3). Callers must ensure correct document outline."

design:
  system:
    - "portfolio"
    - "print-inspired layout"
  interactions:
    - "image lazy/eager loading"

dependencies:
  styles:
    - "tailwind"
    - "inner-border"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
  reviewTriggers:
    - "atom component path changes"
    - "heading-level changes"
    - "inner-border utility removal"

tags:
  - "molecule"
  - "card"
  - "nunjucks"
  - "macro"
---

{% import "atoms/heading.njk" as Heading %}
{% import "atoms/cta.njk" as CTA %}
{% import "molecules/stats/stats.njk" as Details %}
{% import "atoms/printmarks/trim-marks.njk" as TrimMarks %}
{% macro render(params = {}) %}
  {# Note that defaults are limited. This gives the caller more control and allows them to pass in empty strings or falsy values if they want to intentionally omit something that might otherwise be pulled from a project object. #}
  {%- set title = params.title -%}
  {%- set eyebrow = params.eyebrow -%}
  {%- set headingLevel = params.headingLevel | default(3) -%}
  {%- set description = params.description -%}
  {%- set byline = params.byline -%}
  {%- set meta = params.meta | default([]) -%}
  {%- set featured = params.featured | default(false) -%}
  {%- set image = params.image -%}
  {%- set url = params.url -%}
  {%- set classes = params.classes -%}
  {%- set imageClasses = params.imageClasses -%}
  {%- set eager = params.eager | default(false) -%}

  {%- set imageSrc = image and (image.src or image.url or image.asset.url or image) -%}
  {%- set imageAlt = image and image.alt or title -%}

  <article
    data-card-el="root"
    class="relative isolate w-full sm:max-w-4xl sm:grid sm:grid-cols-3 sm:inner-border sm:p-4 sm:mx-auto {{ classes }}">

    {% if imageSrc %}
      <figure data-card-el="figure" class="m-0 relative z-0 overflow-hidden w-full h-dvh sm:h-full sm:p-2">
        {{ TrimMarks.render({ inset: "6", size: "4", weight: "1", color: "white", classes:"invisible sm:visible" }) }}
        <img data-card-el="image" src="{{ imageSrc }}" alt="{{ imageAlt }}" class="h-full object-cover object-center {{ imageClasses }}" loading="{{ 'eager' if eager else 'lazy' }}"/>
      </figure>
    {% endif %}

    <div data-card-el="body" class="bg-white inner-border sm:inner-border-none space-y-2 p-6 sm:col-span-2">

      <header>
        {% if eyebrow %}
          <p class="eyebrow text-xs text-current uppercase tracking-wide">{{ eyebrow }}</p>
        {% endif %}
        {{ Heading.render({ level: headingLevel, text: title, class: "title font-display text-current font-bold sm:text-lg" ~ (" hover:underline" if url else "") }) }}
        {% if byline %}
          <p class="byline text-sm text-current font-thin">{{ byline }}</p>
        {% endif %}
      </header>

      {% if description %}
        <p class="description text-sm text-current">{{ description }}</p>
      {% endif %}

      <footer class="mt-8 pt-4">
        {% if meta | length %}
          {{ Details.render({ stats: meta }) }}
        {% endif %}
        {% if url %}
          {{ CTA.render({ text: "view case study", url: url, classes: "mt-4 font-display inline-block uppercase text-right w-full" }) }}
        {% endif %}
      </footer>

    </div>

  </article>
{% endmacro %}