---
template:
  id: "templates.molecules.section-cap"
  name: "Section Cap"
  type: "molecule"
  status: "active"

source:
  path: "frontend/views/molecules/section-cap.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders a section caption bar showing prefix, count, title, and build timestamp."
  role: "Section metadata display used at section boundaries for print-inspired layout navigation cues."

data:
  expects:
    - "params.prefix (default: 'section')"
    - "params.count"
    - "params.title"
    - "params.classes"
    - "params.buildDate"
  provides:
    - "inline section label with prefix, count, title, and formatted ISO datetime"

design:
  system:
    - "portfolio"
    - "print-inspired layout"

dependencies:
  styles:
    - "tailwind"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
  reviewTriggers:
    - "date format filter changes"
    - "section layout changes"

tags:
  - "molecule"
  - "section"
  - "navigation"
  - "nunjucks"
  - "macro"
---

{# Current Section Title - a simple text element that displays the id of its parent and its location with respect to its siblings. #}
{% macro render(params = {}) %}
  {%- set prefix = params.prefix | default("section") -%}
  {%- set count = params.count | default("") -%}
  {%- set title = params.title | default("") -%}
  {%- set classes = params.classes | default("") -%}
  {%- set buildDate = params.buildDate -%}
  <span data-current-section-prefix>{{ prefix }}</span>
  <span data-current-section-count>{{ count }}</span>
  <span data-current-section-title>: {{ title }}</span>
  <time class="ml-auto text-right text-neutral-300" datetime="{{ buildDate | formatDate("yyyy-MM-dd'T'HH:mm:ss'Z'") }}">{{ buildDate | formatDate("yyyy.MM.dd'T'HH:mm:ss'Z'") }}</time>
{% endmacro %}