---
template:
  id: "templates.molecules.loader-stack"
  name: "Loader Stack"
  type: "molecule"
  status: "active"

source:
  path: "frontend/views/molecules/LoaderStack.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders a loading state with a logo mark, animated indicator, and optional message text."
  role: "Page or section loading overlay used during async data fetch or route transitions."

data:
  expects:
    - "params.message (default: 'Loading\u2026')"
    - "params.kind (default: 'spinner')"
    - "params.markText (default: 'dataink.io')"
    - "params.showText (default: true)"
  provides:
    - "loader UI with mark, indicator, and message"

components:
  uses:
    - "atoms/loader/LoaderMark.njk"
    - "atoms/loader/LoaderIndicator.njk"
    - "atoms/loader/LoaderText.njk"

a11y:
  headingContext:
    notes: "No heading; purely presentational loading UI."

dependencies:
  styles:
    - "tailwind"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
  reviewTriggers:
    - "loader atom path changes"

tags:
  - "molecule"
  - "loader"
  - "nunjucks"
  - "macro"
---

{% import "atoms/loader/LoaderMark.njk" as Mark %}
{% import "atoms/loader/LoaderIndicator.njk" as Indicator %}
{% import "atoms/loader/LoaderText.njk" as LoaderText %}

{% macro render(params = {}) -%}
  {%- set message = params.message | default("Loading…") -%}
  {%- set kind = params.kind | default("spinner") -%}
  <div class="flex flex-col items-center text-center gap-1">
    {{ Mark.render(params.markText or "dataink.io") }}
    {{ Indicator.render(kind) }}
    {% if params.showText | default(true) and LoaderText.render %}
      {{ LoaderText.render(message) }}
    {% endif %}
  </div>
{%- endmacro %}