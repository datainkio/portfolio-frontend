---
template:
  id: "templates.molecules.background.sizzle-background"
  name: "Sizzle Background"
  type: "molecule"
  status: "active"

source:
  path: "frontend/views/molecules/background/sizzle-background.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders a full-screen video background with gel color overlays and a pixelator texture."
  role: "Ambient page backdrop for hero and landing sections; drives the kinetic scroll visual identity."

data:
  expects:
    - "params.videoSrc"
    - "params.poster"
    - "params.defer (default: true)"
    - "params.autoPlay (default: false)"
    - "params.loop (default: true)"
    - "params.muted (default: true)"
    - "params.playsInline (default: true)"
    - "params.preload (default: 'metadata')"
    - "params.id (default: 'sizzle-background')"
    - "params.classes"
    - "params.styles"
  provides:
    - "fixed full-screen video with gel color overlays and pixelator texture"

components:
  uses:
    - "atoms/video/video.njk"
    - "atoms/gel.njk"

a11y:
  headingContext:
    notes: "aria-hidden and inert; purely decorative."

design:
  system:
    - "portfolio"
    - "kinetic scroll"
  interactions:
    - "GSAP fade animation via gsap-element gsap-fade classes"
    - "deferred video loading"

dependencies:
  styles:
    - "tailwind"
  scripts:
    - "gsap"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
  doNotEdit:
    - "rendered markup"
    - "Nunjucks logic"
    - "gel layer order"
  reviewTriggers:
    - "video atom changes"
    - "gel token changes"
    - "GSAP animation class changes"
    - "pixelator texture changes"

tags:
  - "molecule"
  - "background"
  - "video"
  - "gsap"
  - "nunjucks"
  - "macro"
---

{% import "atoms/video/video.njk" as videoAtom %}
{% import "atoms/gel.njk" as Gel %}
{% macro render(params = {}) %}
  {%- set bgID = params.id | default('sizzle-background') -%}
  {%- set containerClasses = params.classes | default('fixed inset-0 -z-10 pointer-events-none overflow-hidden') -%}
  {%- set containerStyles = params.styles | default('') -%}
  <div id="{{ bgID }}" style="{{ containerStyles }}" class="{{ containerClasses }}" aria-hidden="true" inert>
    {{ videoAtom.render({
      src: params.videoSrc,
      defer: params.defer | default(true),
      poster: params.poster | default(''),
      autoplay: params.autoPlay | default(false),
      loop: params.loop | default(true),
      muted: params.muted | default(true),
      playsInline: params.playsInline | default(true),
      preload: params.preload | default("metadata"),
      classes: "absolute inset-0 w-full h-full object-cover object-center -z-10 pointer-events-none gsap-element gsap-fade",
      styles: ""
    }) }}
    {{ Gel.render({ id: 'bg-gel-0', color: 'bg-gel-primary' }) }}
    {{ Gel.render({ id: 'bg-gel-1', color: 'bg-gel-accent' }) }}
    {{ Gel.render({ id: 'bg-gel-2', color: 'bg-gel-secondary' }) }}
    {{ Gel.render({ id: 'bg-gel-3', color: 'bg-gel-success' }) }}
    {{ Gel.render({ id: 'bg-gel-4', color: 'bg-gel-black' }) }}
    <div class="absolute inset-0 bg-pixelator opacity-60 pointer-events-none z-10"></div>
  </div>
{% endmacro %}