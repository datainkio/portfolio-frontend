{% import "molecules/list/project-cards.njk" as ProjectCards %}
{% macro render(params = {}) %}
  <section
    data-projects-el="industry-group"
    class="relative z-10 col-span-full"
    aria-labelledby="industry-{{ params.industryTitle | slugify }}">
    <h3
      id="industry-{{ params.industryTitle | slugify }}"
      data-projects-el="industry-heading"
      class="z-21 -rotate-1 arrow-prefix bg-white outline outline-1 outline-black outline-offset-[-6px] p-4 font-display font-bold
        text-xl px-4 mb-4">{{ params.industryLabelIndex }}
      {{ params.industryTitle }}</h3>
    {{ ProjectCards.render({ projects: params.projects, classes: "col-span-full" }) }}
  </section>
{% endmacro %}