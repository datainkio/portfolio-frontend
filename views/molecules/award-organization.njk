{# UNUSED - No references found in codebase, safe to remove #}
<div
  class="award-organization flex flex-row flex-wrap">
  {# Get the logo for the award organization #}
  {% set image = collections.images | findRecord(awards[0].logo_id) %}
  {# assume that award logos are always SVG #}
  {% picture image[0].file.html, "basis-1/6", "size-6" %}
  <h4 class="basis-5/6">{{ orgName }}</h4>
  <ul class="basis-5/6 list-none">
    {% for award in awards %}
      <li class="text-sm pl-6">{{ award.title }}</li>
    {% endfor %}
  </ul>
</div>