---
template:
  id: "templates.molecules.form"
  name: "Form"
  type: "partial"
  status: "draft"

source:
  path: "frontend/views/molecules/form.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Renders a basic HTML form with a name input and submit button."
  role: "Placeholder contact form; incomplete — not yet wired to a backend endpoint."

data:
  expects:
    - "action (form POST URL)"
  provides:
    - "form with name input and submit button"

a11y:
  headingContext:
    notes: "No heading; relies on surrounding page context for labeling."

dependencies:
  styles:
    - "tailwind"

agent:
  owner: "Template Steward"
  safeToEdit:
    - "frontmatter"
    - "comments"
    - "rendered markup"
  doNotEdit: []
  reviewTriggers:
    - "backend form handling changes"
    - "accessibility audit"

tags:
  - "molecule"
  - "form"
  - "nunjucks"
  - "draft"
---

<form action="{{ action }}" method="POST" class="form-control">
  {% include "atoms/input.njk" with { placeholder: "Your Name" } %}
  {% include "atoms/button.njk" with { label: "Submit", type: "success" } %}
</form>