---
template:
  id: "templates.registry"
  name: "Component Registry"
  type: "partial"
  status: "active"

source:
  path: "frontend/views/_registry.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Centralised component discovery system — provides a single interface for importing and rendering any component by tier and name."
  role: "Used during development and documentation; production templates should prefer direct includes."

agent:
  safeToEdit:
    - "frontmatter"
  doNotEdit:
    - "import macro logic"
  reviewTriggers:
    - "directory structure changes"
    - "new component tiers added"

tags:
  - "registry"
  - "components"
  - "dx"
  - "nunjucks"
---

{# Component Registry Macro - Central Component Loader #}
{# Note: For complex props, use direct includes. This is for simple documentation. #}{% macro component(category, name, note="Use direct includes for complex props") %}
  <!-- Component: {{ category }}/{{ name }} -->
  <!-- {{ note }} --><!-- Example: {% include "{{ category }}/{{ name }}.njk" %} -->
{% endmacro %}

{# Icon Helper - Shorthand for icon components #}
{% macro icon(name, size="md", className="") %}
  {% include "atoms/icon.njk" %}
{% endmacro %}

{# Button Helper - Shorthand for button components #}
{% macro button(label, type="primary", btnStyles="", disabled=false, onclick="") %}
  {% include "atoms/button/button.njk" %}
{% endmacro %}

{# Component List Generator - For development and documentation #}
{% macro listComponents(category="all") %}
  <!-- Component Registry: Available Components -->
  <!-- ATOMS:
  - icon (consolidated icon system)
  - button/button (primary UI actions)
  - avatar (user profile images)
  - heading (typography hierarchy)
  - link/* (navigation and external links)
  - video/* (media components) MOLECULES:
  - (scan molecules/ directory for components) ORGANISMS:
  - section/* (page sections with GSAP integration) TEMPLATES:
  - base (main layout with GSAP and design tokens)
  - blog, documentation, landing, parallax USAGE: {% from "_registry.njk" import component, icon, button %} {{
  component("atoms", "icon", { name: "chevron-down" }) }} --> {{ button("Click Me", "primary") }}
  <!-- Shorthand -->
-->
{% endmacro %}

{# Component Validation Helper #}
  {% macro validateComponent(componentData, requiredProps=[]) %}
    {% for prop in requiredProps %}{% if not componentData[prop] %}
      <!-- VALIDATION ERROR: Missing required prop "{{ prop }}" -->
    {% endif %}
  {% endfor %}
{% endmacro %}

{# Design Token Helper - Access Figma design tokens #}
{% macro designToken(category, name, fallback="") %}
  {% set tokenPath = "var(--" + category + "-" + name + ")" %}
  {% if fallback %}
    {{ tokenPath }}, {{ fallback }}
  {% else %}
    {{ tokenPath }}
  {% endif %}
{% endmacro %}