---
template:
  id: "templates.pages.home"
  name: "Home Page"
  type: "page"
  status: "active"

source:
  path: "frontend/views/pages/home.njk"
  engine: "nunjucks"
  eleventyLayout: false

purpose:
  summary: "Primary portfolio landing page — full custom layout composing all homepage sections with site preloader, background, and choreography."
  role: "Orchestrates hero, bio, awards, work, organizations, and contact sections from frontmatter-driven content values."

data:
  expects:
    - "title"
    - "landing (frontmatter content values for each section)"
    - "collections.projects"
    - "collections.recognition"
    - "collections.organizations"
    - "cms.navigation"
  provides:
    - "complete homepage document"

components:
  uses:
    - "organisms/SitePreloader.njk"
    - "organisms/header/global-header.njk"
    - "organisms/footer/global-footer.njk"
    - "organisms/navigation/skip-links-nav.njk"
    - "molecules/background/sizzle-background.njk"
    - "organisms/section/hero.njk"
    - "organisms/section/bio.njk"
    - "organisms/section/awards.njk"
    - "organisms/section/work.njk"
    - "organisms/section/organizations.njk"
    - "organisms/section/contact.njk"
    - "templates/partials/head.njk"
    - "templates/partials/gtm-noscript.njk"

design:
  interactions:
    - "GSAP ScrollTrigger section choreography"
    - "StageManager scroll-based background"
    - "SitePreloader loading sequence"

tags:
  - "page"
  - "homepage"
  - "landing"
  - "gsap"
  - "sanity"
---

{# FUNCTIONALITY IMPORTS #}
{% import "organisms/SitePreloader.njk" as Preloader %}
{% import "organisms/header/global-header.njk" as Header with context %}
{% import "organisms/footer/global-footer.njk" as Footer with context %}

{# UX IMPORTS #}
{% import "organisms/navigation/skip-links-nav.njk" as SkipLinksNav %}
{% import "molecules/background/sizzle-background.njk" as Background %}

{# SECTION CONTENT #}
{% import "organisms/section/hero.njk" as heroSection %}
{% import "organisms/section/bio.njk" as bioSection %}
{% import "organisms/section/awards.njk" as awardsSection %}
{% import "organisms/section/work.njk" as projectsSection %}
{% import "organisms/section/organizations.njk" as organizationsSection %}
{% import "organisms/section/contact.njk" as contactSection %}

{# SECTION STYLING #}
{% set sharedClasses = "" %}
{# Note that content values are set in frontmatter #}
<!DOCTYPE html>
<html lang="en" class="bg-slate-950">
  {% include "templates/partials/head.njk" %}
  <body>
    {% include "templates/partials/gtm-noscript.njk" %}
    {# {{ SkipLinksNav.render({ items: ["hero", "introduction", "recognition", "work", "organizations", "contact"] }) }} #}
    {{ Header.render({classes: 'bg-transparent font-display text-white'}) }}
    {{ Preloader.render({ kind: "spinner", message: "Lubricating the framistan…" }) }}
    {{ Background.render({
            id:"background",
            videoSrc: hero.videoSrc,
            defer: false,
            preload: "none",
            autoPlay: true
            }) }}
    <main id="page-main" aria-busy="true" class="max-w-2xl mx-auto space-y-48 col-span-full grid grid-cols-12">
      <div id="page-main-content" class="col-span-12 space-y-48">
        {# Note that content values are set in frontmatter #}
        {# The id param has a matching value in SELECTORS.js for consistency w/choreography during runtime #}
        {{ heroSection.render( { id: "hero", tagline: hero.tagline, classes: sharedClasses }) }}
        {{ bioSection.render({ id: "introduction", copy: value, order: "1/5", classes: sharedClasses, buildDate: buildDate}) }}
        {{ projectsSection.render({ id: "work", copy: work, projectsByIndustry: collections.projectsByIndustry, classes: sharedClasses, order: "3/5", buildDate: buildDate }) }}
        {{ awardsSection.render({ id: "recognition", copy: recognition, awards: collections.awards, order: "2/5", classes: sharedClasses, buildDate: buildDate }) }}
        {{ organizationsSection.render({ id: "organizations", organizations: collections.organizations, classes: sharedClasses, order: "4/5", buildDate: buildDate }) }}
      {{ contactSection.render({ id: "contact", copy: contact, classes: sharedClasses, order: "5/5", buildDate: buildDate }) }}
    </div>
    </main>
    {{ Footer.render() }}
  {% include "templates/partials/choreography-script.njk" %}
</body></html>