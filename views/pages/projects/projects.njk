{% extends "templates/landing/landing.njk" %}
{% import "molecules/list/project-cards.njk" as ProjectCards %}
{%- set list = {
  "base": "col-span-full grid grid-cols-1 gap-8",
  "sm": "bg-primary-950 space-y-12",
  "md": "",
  "lg": "",
  "xl": ""
} -%}
{%- set article = {
  "base": [
    "col-span-full grid grid-cols-12 gap-8",
    "[&>p]:col-start-4 [&>p]:col-span-8",
    "[&>h2]:col-start-4 [&>h2]:col-span-8",
    "[&>ul]:col-start-4 [&>ul]:col-span-8 [&>ol]:col-start-4 [&>ol]:col-span-8"
]} -%}
{%- set header = {
    "base": "col-span-full grid grid-cols-subgrid px-0 gap-x-4 gap-y-10 p-8 pb-24 content-end h-[90dvh] bg-black z-10 overflow-hidden text-neutral-100",
    "sm": "px-12 gap-y-12",
    "md": "px-16 gap-y-14",
    "lg": "px-24 gap-y-8",
    "xl": ""
  } -%}

{% block content %}
  {{ super() }}
  {% if collections.projects and collections.projects.length %}
    {{ ProjectCards.render({ projects: collections.projects, classes: list | classes }) }}
  {% else %}
    <p>No projects found.</p>
  {% endif %}
  {% include "templates/partials/choreography-script.njk" %}
{% endblock %}