{% extends "layouts/base.njk" %}
{% import "organisms/project-metadata/project-metadata.njk" as ProjectMetadata %}

{#
  Single project page template.
  Data: paginated from `collections.projectPages`, aliased as `project`
  (see ../../../ia/project.md). Shape produced by
  `frontend/data/sanity/transforms/project.js` + `projectPageProjection.js`.
  Spec: frontend/specs/views/project-page.views-spec.md
  Pattern: content-model/patterns/project-page.md
#}

{%- set bodyClasses = "bg-white grid grid-cols-12" -%}
{%- set mainClasses = "col-span-full w-full" -%}

{# ─── Styles ──────────────────────────────────────────────────────────────── #}

{%- set article        = { "base": "project-page w-full space-y-12" } -%}
{%- set header         = { "base": "project-page__header space-y-3 bg-black text-white" } -%}
{%- set title          = { "base": "project-page__title text-4xl font-black tracking-tight" } -%}
{%- set byline         = { "base": "project-page__byline text-sm uppercase tracking-wide text-gray-600" } -%}
{%- set metadata       = {
  "base": "project-page__metadata grid gap-6",
  "md": "md:grid-cols-2",
  "lg": "lg:grid-cols-4"
} -%}
{%- set figure         = { "base": "project-page__featured-image" } -%}
{%- set abstract       = { "base": "project-page__abstract text-xl text-gray-800" } -%}
{%- set aside          = { "base": "project-page__outcome border-l-4 border-primary-500 pl-6 py-2" } -%}
{%- set body           = { "base": "project-page__body prose prose-lg max-w-none" } -%}
{%- set projectLink    = { "base": "project-page__external-link underline underline-offset-4" } -%}
{%- set outcomeHeading = { "base": "project-page__outcome-heading text-xs font-semibold uppercase tracking-wide text-gray-600" } -%}

{# ─── Data guards ─────────────────────────────────────────────────────────── #}

{%- set orgs             = project.organization or [] -%}
{%- set hasByline        = orgs | length -%}
{%- set hasFeaturedImage = project.featuredImage and project.featuredImage.asset and project.featuredImage.asset.url -%}
{%- set hasOutcomes      = project.outcomes and project.outcomes | length -%}
{%- set hasBody          = project.bodyHtml | length > 0 -%}
{%- set externalLinkHref =
  (project.externalLink.href if project.externalLink and project.externalLink.href else
    (project.externalLink if project.externalLink is string else "")) -%}
{%- set externalLinkLabel =
  (project.externalLink.label if project.externalLink and project.externalLink.label else "Visit live project") -%}

{% block content %}
  <article
    class="{{ article | classes }}" aria-labelledby="project-title">

    {# 1. Title + byline (single H1 on the page) #}
    <header class="{{ header | classes }}">
      <h1 id="project-title" class="{{ title | classes }}">
        {{ project.title }}
      </h1>
      {% if hasByline %}
        <p class="{{ byline | classes }}">
          <span>
            {%- for org in orgs -%}
              {{ org.title }}
              {% if not loop.last %},
              {% endif %}
            {%- endfor -%}
          </span>
        </p>
      {% endif %}
      {{ ProjectMetadata.render({ project: project, classes: metadata | classes, aria: "Project metadata" }) }}
    </header>

    {# 2. Abstract #}
    {% if project.abstract %}
      <p class="{{ abstract | classes }}">
        {{ project.abstract }}
      </p>
    {% endif %}

    {# 3. Featured image #}
    {% if hasFeaturedImage %}
      <figure class="{{ figure | classes }}">
        <img src="{{ project.featuredImage.asset.url }}" alt="{{ project.featuredImage.alt | default(project.title) }}" {% if project.featuredImage.asset.metadata and project.featuredImage.asset.metadata.dimensions %} width="{{ project.featuredImage.asset.metadata.dimensions.width }}" height="{{ project.featuredImage.asset.metadata.dimensions.height }}" {% endif %} loading="eager" decoding="async" class="w-full h-auto"/>
        {% if project.featuredImage.caption %}
          <figcaption class="mt-2 text-sm text-gray-600">
            {{ project.featuredImage.caption }}
          </figcaption>
        {% endif %}
      </figure>
    {% endif %}

    {# 5. Outcome (optional, distinct treatment) #}
    {% if hasOutcomes %}
      <aside class="{{ aside | classes }}" aria-labelledby="project-outcome-heading">
        <h2 id="project-outcome-heading" class="{{ outcomeHeading | classes }}">
          Outcome{% if project.outcomes | length > 1 %}s{% endif %}
        </h2>
        <ul class="mt-2 space-y-1 text-lg">
          {% for outcome in project.outcomes %}
            <li>{{ outcome.title }}</li>
          {% endfor %}
        </ul>
      </aside>
    {% endif %}

    {# 6. Body (Portable Text → HTML, prepared by transform; H2+ only) #}
    {% if hasBody %}
      <section class="{{ body | classes }}" aria-label="Project narrative">
        {{ project.bodyHtml | safe }}
      </section>
    {% endif %}

    {# 7. Link to live project (optional) #}
    {% if externalLinkHref %}
      <a href="{{ externalLinkHref }}" rel="noopener noreferrer" target="_blank" class="{{ projectLink | classes }}">
        {{ externalLinkLabel }}
      </a>
    {% endif %}

    {# 8. End CTA — provided by site-global footer contact form. #}
    {# Intentionally no inline CTA: conversion handled in global footer. #}
  </article>
{% endblock %}